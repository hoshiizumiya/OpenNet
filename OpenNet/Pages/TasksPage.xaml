<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="OpenNet.Pages.TasksPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:OpenNet.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:vm="using:OpenNet.ViewModels"
    x:Uid="TasksPageRoot"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <!--  NewWindow  -->
        <!--<AutoSuggestBox Width="280" QueryIcon="Find" />-->
        <AutoSuggestBox
            x:Name="SearchBox"
            Width="280"
            Margin="12,6"
            HorizontalAlignment="Left"
            PlaceholderText="Search"
            QueryIcon="Find" />
        <!--  TextChanged="SearchBox_TextChanged"  -->
        <CommandBar Grid.Row="0" DefaultLabelPosition="Right">
            <AppBarButton
                x:Uid="TaskNewButton"
                Command="{x:Bind ViewModel.NewCommand}"
                Icon="Add" />
            <AppBarButton
                x:Uid="TaskStartButton"
                Command="{x:Bind ViewModel.StartCommand}"
                Icon="Play" />
            <AppBarButton
                x:Uid="TaskPauseButton"
                Command="{x:Bind ViewModel.PauseCommand}"
                Icon="Pause" />
            <AppBarButton
                x:Uid="TaskDeleteButton"
                Command="{x:Bind ViewModel.DeleteCommand}"
                Icon="Delete" />
            <CommandBar.SecondaryCommands>
                <AppBarButton Icon="Setting" Label="Settings">
                    <AppBarButton.KeyboardAccelerators>
                        <KeyboardAccelerator Key="I" Modifiers="Control" />
                    </AppBarButton.KeyboardAccelerators>
                </AppBarButton>
            </CommandBar.SecondaryCommands>

        </CommandBar>

        <SplitView
            Grid.Row="1"
            DisplayMode="Inline"
            IsPaneOpen="True"
            OpenPaneLength="50">
            <SplitView.Pane>
                <!--  左侧筛选导航 / Left-side filter navigation  -->
                <muxc:NavigationView
                    x:Name="FilterNavView"
                    IsBackButtonVisible="Collapsed"
                    IsPaneToggleButtonVisible="False"
                    IsSettingsVisible="False"
                    PaneDisplayMode="LeftCompact"
                    SelectionChanged="FilterNavView_SelectionChanged">
                    <muxc:NavigationView.MenuItems>
                        <muxc:NavigationViewItem
                            Content="全部任务"
                            Icon="ViewAll"
                            IsSelected="True"
                            Tag="AllTasks" />
                        <muxc:NavigationViewItem
                            Content="正在下载"
                            Icon="Download"
                            Tag="Downloading" />
                        <muxc:NavigationViewItem
                            Content="已完成"
                            Icon="Accept"
                            Tag="Completed" />
                        <muxc:NavigationViewItem
                            Content="已失败"
                            Icon="Cancel"
                            Tag="Failed" />
                    </muxc:NavigationView.MenuItems>
                </muxc:NavigationView>
            </SplitView.Pane>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="2*" />
                </Grid.RowDefinitions>

                <!--  顶部任务列表（使用内置 ListView 模拟 DataGrid 样式）  -->
                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>


                    <!--  列头  -->
                    <Grid
                        Grid.Row="0"
                        Padding="8,4"
                        Background="{ThemeResource SystemControlAcrylicWindowBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            x:Uid="Header_TaskName"
                            Grid.Column="0"
                            FontWeight="SemiBold" />
                        <TextBlock
                            x:Uid="Header_Size"
                            Grid.Column="1"
                            Text="Size" />
                        <TextBlock
                            x:Uid="Header_Progress"
                            Grid.Column="2"
                            Text="Progress" />
                        <TextBlock
                            x:Uid="Header_DLRate"
                            Grid.Column="3"
                            Text="DL Rate" />
                        <TextBlock
                            x:Uid="Header_Remaining"
                            Grid.Column="4"
                            Text="Remaining" />
                        <TextBlock
                            x:Uid="Header_AddDate"
                            Grid.Column="5"
                            Text="Add Date" />
                    </Grid>

                    <!--  列表  -->
                    <ListView
                        x:Name="TasksList"
                        Grid.Row="1"
                        ItemsSource="{x:Bind ViewModel.FilteredTasks, Mode=OneWay}"
                        SelectionMode="Extended">
                        <ListView.ItemTemplate>
                            <!--  在这里写DataType可以在绑定时省略命名空间前缀  -->
                            <DataTemplate x:DataType="vm:TaskViewModel">
                                <Grid Padding="8,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="2*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{x:Bind Name, Mode=OneWay}" />
                                    <TextBlock Grid.Column="1" Text="{x:Bind Size, Mode=OneWay}" />
                                    <TextBlock Grid.Column="2" Text="{x:Bind Progress, Mode=OneWay}" />
                                    <TextBlock Grid.Column="3" Text="{x:Bind DownloadRate, Mode=OneWay}" />
                                    <TextBlock Grid.Column="4" Text="{x:Bind Remaining, Mode=OneWay}" />
                                    <TextBlock Grid.Column="5" Text="{x:Bind AddDate, Mode=OneWay}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>

                <!--  上下可调分隔条（WinUI 控件命名空间）  -->
                <!--<muxc:gridsplitter
                    grid.row="1"
                    height="5"
                    horizontalalignment="stretch"
                    resizebehavior="basedonalignment"
                    resizedirection="rows" />-->

                <!--  下方多标签  -->
                <!--  SelectionChanged=""  -->
                <muxc:SelectorBar x:Name="Task_SelectBar" Grid.Row="2">
                    <muxc:SelectorBarItem
                        x:Name="SummaryContent"
                        x:Uid="Task_SummaryContent"
                        IsSelected="True" />
                    <muxc:SelectorBarItem x:Name="PeersList" x:Uid="Task_PeersList" />
                </muxc:SelectorBar>
            </Grid>
        </SplitView>
    </Grid>
</Page>
