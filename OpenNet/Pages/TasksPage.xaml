<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="OpenNet.Pages.TasksPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:OpenNet.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:vm="using:OpenNet.ViewModels"
    x:Uid="TasksPageRoot"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <!--  NewWindow  -->
        <CommandBar Grid.Row="0" DefaultLabelPosition="Right">
            <AppBarButton x:Uid="TaskStartButton" Icon="Play" Command="{x:Bind ViewModel.StartCommand}" />
            <AppBarButton x:Uid="TaskPauseButton" Icon="Pause" Command="{x:Bind ViewModel.PauseCommand}" />
            <AppBarButton x:Uid="TaskNewButton" Icon="Add" Command="{x:Bind ViewModel.NewCommand}" />
            <CommandBar.SecondaryCommands>
                <AppBarButton Icon="Setting" Label="Settings">
                    <AppBarButton.KeyboardAccelerators>
                        <KeyboardAccelerator Key="I" Modifiers="Control" />
                    </AppBarButton.KeyboardAccelerators>
                </AppBarButton>
            </CommandBar.SecondaryCommands>

            <!--<AutoSuggestBox Width="280" QueryIcon="Find"/>-->
        </CommandBar>

        <SplitView
            Grid.Row="1"
            DisplayMode="Inline"
            IsPaneOpen="True"
            OpenPaneLength="260">
            <SplitView.Pane>
                <!--  WinUI TreeView  -->
                <muxc:TreeView />
            </SplitView.Pane>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="2*" />
                </Grid.RowDefinitions>

                <!--  顶部任务列表（使用内置 ListView 模拟 DataGrid 样式）  -->
                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>


                    <!--  列头  -->
                    <Grid
                        Grid.Row="0"
                        Padding="8,4"
                        Background="{ThemeResource SystemControlAcrylicWindowBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="0"
                            FontWeight="SemiBold"
                            Text="Name" />
                        <TextBlock Grid.Column="1" Text="Size" />
                        <TextBlock Grid.Column="2" Text="Progress" />
                        <TextBlock Grid.Column="3" Text="DL Rate" />
                        <TextBlock Grid.Column="4" Text="Remaining" />
                    </Grid>

                    <!--  列表  -->
                    <ListView
                        x:Name="TasksList"
                        Grid.Row="1"
                        ItemsSource="{x:Bind ViewModel.Tasks, Mode=OneWay}"
                        SelectionMode="Extended">
                        <ListView.ItemTemplate>
                            <!--  在这里写DataType可以在绑定时省略命名空间前缀  -->
                            <DataTemplate x:DataType="vm:TaskViewModel">
                                <Grid Padding="8,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="2*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{x:Bind Name, Mode=OneWay}" />
                                    <TextBlock Grid.Column="1" Text="{x:Bind Size, Mode=OneWay}" />
                                    <TextBlock Grid.Column="2" Text="{x:Bind Progress, Mode=OneWay}" />
                                    <TextBlock Grid.Column="3" Text="{x:Bind DownloadRate, Mode=OneWay}" />
                                    <TextBlock Grid.Column="4" Text="{x:Bind Remaining, Mode=OneWay}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>

                <!--  上下可调分隔条（WinUI 控件命名空间）  -->
                <!--<muxc:gridsplitter
                    grid.row="1"
                    height="5"
                    horizontalalignment="stretch"
                    resizebehavior="basedonalignment"
                    resizedirection="rows" />-->

                <!--  下方多标签  -->
                <muxc:TabView Grid.Row="2">
                    <muxc:TabViewItem Header="Summary">
                        <TextBlock Margin="12" Text="Summary content" />
                    </muxc:TabViewItem>
                    <muxc:TabViewItem Header="Peers">
                        <TextBlock Margin="12" Text="Peers content" />
                    </muxc:TabViewItem>
                </muxc:TabView>
            </Grid>
        </SplitView>
    </Grid>
</Page>
