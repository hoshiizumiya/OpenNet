<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="OpenNet.Pages.TasksPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:XamlToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:OpenNet.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:vm="using:OpenNet.ViewModels"
    x:Uid="TasksPageRoot"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <!--  NewWindow  -->
        <!--<AutoSuggestBox Width="280" QueryIcon="Find" />-->
        <AutoSuggestBox
            x:Name="SearchBox"
            Width="280"
            Margin="12,6"
            HorizontalAlignment="Left"
            PlaceholderText="Search"
            QueryIcon="Find"
            TextChanged="SearchBox_TextChanged"/>
        <CommandBar Grid.Row="0"
                    DefaultLabelPosition="Right">
            <AppBarButton
                x:Name="TaskNewButton"
                x:Uid="TaskNewButton"
                Icon="Add">
                <muxc:AppBarButton.Flyout>
                    <muxc:MenuFlyout Placement="Bottom">
                        <muxc:MenuFlyoutItem
                            x:Name="MenuItemAddFromLink"
                            x:Uid="TaskNewFromUrlButton"
                            Click="MenuItemAddFromLink_ClickAsync"
                            Icon="Link"
                            Text="From Link"/>
                        <muxc:MenuFlyoutItem
                            x:Name="MenuItemAddFromFile"
                            x:Uid="TaskNewFromFileButton"
                            Click="MenuItemAddFromFile_ClickAsync"
                            Icon="Document"
                            Text="From File"/>
                        <muxc:MenuFlyoutSeparator/>
                        <muxc:MenuFlyoutItem
                            x:Name="MenuItemAddFromHttp"
                            x:Uid="TaskNewFromHttpButton"
                            Click="MenuItemAddFromHttp_ClickAsync"
                            Text="HTTP Download">
                            <muxc:MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE774;"/>
                            </muxc:MenuFlyoutItem.Icon>
                        </muxc:MenuFlyoutItem>
                    </muxc:MenuFlyout>
                </muxc:AppBarButton.Flyout>
            </AppBarButton>
            <AppBarButton
                x:Uid="TaskStartButton"
                Command="{x:Bind ViewModel.StartCommand}"
                Icon="Play"/>
            <AppBarButton
                x:Uid="TaskPauseButton"
                Command="{x:Bind ViewModel.PauseCommand}"
                Icon="Pause"/>
            <AppBarButton
                x:Uid="TaskDeleteButton"
                Command="{x:Bind ViewModel.DeleteCommand}"
                Icon="Delete"/>
            <CommandBar.SecondaryCommands>
                <AppBarButton Icon="Setting"
                              Label="Settings">
                    <AppBarButton.KeyboardAccelerators>
                        <KeyboardAccelerator Key="I"
                                             Modifiers="Control"/>
                    </AppBarButton.KeyboardAccelerators>
                </AppBarButton>
            </CommandBar.SecondaryCommands>

        </CommandBar>

        <SplitView
            Grid.Row="1"
            DisplayMode="Inline"
            IsPaneOpen="True"
            OpenPaneLength="50">
            <SplitView.Pane>
                <!--  左侧筛选导航 / Left-side filter navigation  -->
                <muxc:NavigationView
                    x:Name="FilterNavView"
                    IsBackButtonVisible="Collapsed"
                    IsPaneToggleButtonVisible="False"
                    IsSettingsVisible="False"
                    PaneDisplayMode="LeftCompact"
                    SelectionChanged="FilterNavView_SelectionChanged">
                    <muxc:NavigationView.MenuItems>
                        <muxc:NavigationViewItem
                            x:Uid="FilterNavViewAllTasks"
                            Icon="ViewAll"
                            IsSelected="True"
                            Tag="AllTasks"/>
                        <muxc:NavigationViewItem
                            x:Uid="FilterNavViewDownloading"
                            Icon="Download"
                            Tag="Downloading"/>
                        <muxc:NavigationViewItem
                            x:Uid="FilterNavViewCompleted"
                            Icon="Accept"
                            Tag="Completed"/>
                        <muxc:NavigationViewItem
                            x:Uid="FilterNavViewFailed"
                            Icon="Cancel"
                            Tag="Failed"/>
                    </muxc:NavigationView.MenuItems>
                </muxc:NavigationView>
            </SplitView.Pane>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="2*"/>
                </Grid.RowDefinitions>

                <!--  顶部任务列表（使用内置 ListView 模拟 DataGrid 样式）  -->
                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>


                    <!--  列头  -->
                    <Grid
                        Grid.Row="0"
                        Padding="8,4"
                        Background="{ThemeResource SystemControlAcrylicWindowBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            x:Uid="Header_TaskName"
                            Grid.Column="0"
                            FontWeight="SemiBold"/>
                        <TextBlock
                            x:Uid="Header_Size"
                            Grid.Column="1"
                            Text="Size"/>
                        <TextBlock
                            x:Uid="Header_Progress"
                            Grid.Column="2"
                            Text="Progress"/>
                        <TextBlock
                            x:Uid="Header_DLRate"
                            Grid.Column="3"
                            Text="DL Rate"/>
                        <TextBlock
                            x:Uid="Header_ULRate"
                            Grid.Column="4"
                            Text="UL Rate"/>
                        <TextBlock
                            x:Uid="Header_Remaining"
                            Grid.Column="5"
                            Text="Remaining"/>
                        <TextBlock
                            x:Uid="Header_AddDate"
                            Grid.Column="6"
                            Text="Add Date"/>
                    </Grid>

                    <!--  列表  -->
                    <ListView
                        x:Name="TasksList"
                        Grid.Row="1"
                        ItemsSource="{x:Bind ViewModel.FilteredTasks, Mode=OneWay}"
                        RightTapped="TasksList_RightTapped"
                        SelectionChanged="TasksList_SelectionChanged"
                        SelectionMode="Single">
                        <ListView.ContextFlyout>
                            <MenuFlyout>
                                <MenuFlyoutItem
                                    x:Name="MoveTaskMenuItem"
                                    x:Uid="MoveTaskMenuItem"
                                    Click="MoveTaskMenuItem_Click"
                                    Icon="MoveToFolder"
                                    Text="Move to..."/>
                                <MenuFlyoutItem
                                    x:Name="OpenTaskLocationMenuItem"
                                    x:Uid="OpenTaskLocationMenuItem"
                                    Click="OpenTaskLocationMenuItem_Click"
                                    Icon="OpenFile"
                                    Text="Open Location"/>
                                <MenuFlyoutSeparator/>
                                <MenuFlyoutItem
                                    x:Name="PropertiesMenuItem"
                                    x:Uid="PropertiesMenuItem"
                                    Click="PropertiesMenuItem_Click"
                                    Icon="More"
                                    Text="Properties"/>
                            </MenuFlyout>
                        </ListView.ContextFlyout>
                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <muxc:ItemsStackPanel Orientation="Vertical"/>
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>
                        <ListView.ItemTemplate>
                            <!--  在这里写DataType可以在绑定时省略命名空间前缀  -->
                            <DataTemplate x:DataType="vm:TaskViewModel">
                                <Grid Padding="8,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="2*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{x:Bind Name, Mode=OneWay}"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{x:Bind Size, Mode=OneWay}"/>
                                    <TextBlock Grid.Column="2"
                                               Text="{x:Bind Progress, Mode=OneWay}"/>
                                    <TextBlock Grid.Column="3"
                                               Text="{x:Bind DownloadRate, Mode=OneWay}"/>
                                    <TextBlock Grid.Column="4"
                                               Text="{x:Bind UploadRate, Mode=OneWay}"/>
                                    <TextBlock Grid.Column="5"
                                               Text="{x:Bind Remaining, Mode=OneWay}"/>
                                    <TextBlock Grid.Column="6"
                                               Text="{x:Bind AddDate, Mode=OneWay}"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>

                <!--  上下可调分隔条（XamlToolkit GridSplitter）  -->
                <controls:GridSplitter
                    Grid.Row="1"
                    Height="8"
                    HorizontalAlignment="Stretch"
                    ResizeBehavior="BasedOnAlignment"
                    ResizeDirection="Rows"/>

                <!--  下方多标签  -->
                <muxc:SelectorBar x:Name="Task_SelectBar"
                                  Grid.Row="2"
                                  SelectionChanged="Task_SelectBar_SelectionChanged">
                    <muxc:SelectorBarItem
                        x:Name="SummaryContent"
                        x:Uid="Task_SummaryContent"
                        IsSelected="True"/>
                    <muxc:SelectorBarItem x:Name="PeersList"
                                          x:Uid="Task_PeersList"/>
                    <muxc:SelectorBarItem x:Name="TrackersList"
                                          x:Uid="Task_TrackersList"/>
                    <muxc:SelectorBarItem x:Name="FilesList"
                                          x:Uid="Task_FilesList"/>
                </muxc:SelectorBar>
                <Frame x:Name="ContentFrame"
                       Grid.Row="3"
                       IsNavigationStackEnabled="False"/>

            </Grid>
        </SplitView>
    </Grid>
</Page>
