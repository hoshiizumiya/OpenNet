<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="OpenNet.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:OpenNet.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>

        <!--  内容区 / Content Area  -->
        <Grid>
            <!--  主页内容 / Home Content  -->
            <ScrollViewer x:Name="HomeContent">
                <StackPanel Padding="24" Spacing="24">
                    <TextBlock
                        FontSize="28"
                        FontWeight="Bold"
                        Text="欢迎使用 OpenNet / Welcome to OpenNet" />

                    <TextBlock
                        FontSize="16"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="安全、高效的点对点文件传输解决方案 / Secure and efficient peer-to-peer file transfer solution" />

                    <!--  快速操作 / Quick Actions  -->
                    <Border
                        Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel Spacing="16">
                            <TextBlock
                                FontSize="18"
                                FontWeight="SemiBold"
                                Text="快速操作 / Quick Actions" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Button
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Margin="4"
                                    Command="{x:Bind ViewModel.StartNetworkDetectionCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="🔍" />
                                        <TextBlock Text="检测网络 / Detect Network" />
                                    </StackPanel>
                                </Button>

                                <Button
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    Margin="4"
                                    Command="{x:Bind ViewModel.ConnectToPeerCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="🔗" />
                                        <TextBlock Text="连接节点 / Connect" />
                                    </StackPanel>
                                </Button>

                                <Button
                                    Grid.Row="0"
                                    Grid.Column="2"
                                    Margin="4"
                                    Command="{x:Bind ViewModel.RefreshCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="🔄" />
                                        <TextBlock Text="刷新 / Refresh" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!--  网络状态 / Network Status  -->
                    <Border
                        Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel Spacing="12">
                            <TextBlock
                                FontSize="18"
                                FontWeight="SemiBold"
                                Text="网络状态 / Network Status" />

                            <TextBlock FontSize="14" Text="{x:Bind ViewModel.NetworkStatusText, Mode=OneWay}" />

                            <TextBlock>
                                <Run Text="网络质量 / Quality: " />
                                <Run FontWeight="Bold" Text="{x:Bind ViewModel.NetworkQualityText, Mode=OneWay}" />
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!--  最近活动 / Recent Activities  -->
                    <Border
                        Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel Spacing="12">
                            <TextBlock
                                FontSize="18"
                                FontWeight="SemiBold"
                                Text="最近活动 / Recent Activities" />

                            <ListView
                                MaxHeight="200"
                                ItemsSource="{x:Bind ViewModel.RecentActivities, Mode=OneWay}"
                                ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <TextBlock
                                            Margin="0,2"
                                            FontSize="12"
                                            Text="{Binding}"
                                            TextWrapping="Wrap" />
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!--  网络状态页面 / Network Status Page  -->
            <Grid x:Name="NetworkContent">
                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="24"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="网络状态页面 / Network Status Page" />
            </Grid>

            <!--  节点列表页面 / Peer List Page  -->
            <Grid x:Name="PeerContent">
                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="24"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="节点列表页面 / Peer List Page" />
            </Grid>

            <!--  文件传输页面 / File Transfer Page  -->
            <Grid x:Name="TransferContent">
                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="24"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="文件传输页面 / File Transfer Page" />
            </Grid>

            <!--  设置页面 / Settings Page  -->
            <Grid x:Name="SettingsContent">
                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="24"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="设置页面 / Settings Page" />
            </Grid>
        </Grid>
    </Grid>
</Page>
