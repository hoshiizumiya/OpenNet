<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="OpenNet.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:OpenNet.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Uid="HomePageRoot"
    mc:Ignorable="d">

    <Grid>

        <!--  内容区 / Content Area  -->
        <Grid>
            <!--  主页内容 / Home Content  -->
            <ScrollViewer x:Name="HomeContent" x:Uid="HomeContent">
                <StackPanel Padding="24" Spacing="24">
                    <TextBlock
                        x:Uid="HomeTitle"
                        FontSize="28"
                        FontWeight="Bold" />

                    <TextBlock
                        x:Uid="HomeSubtitle"
                        FontSize="16"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                    <!--  快速操作 / Quick Actions  -->
                    <Border
                        x:Uid="QuickActionsCard"
                        Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel Spacing="16">
                            <TextBlock
                                x:Uid="QuickActionsTitle"
                                FontSize="18"
                                FontWeight="SemiBold" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Button
                                    x:Uid="DetectNetworkButton"
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Margin="4"
                                    Command="{x:Bind ViewModel.StartNetworkDetectionCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="🔍" />
                                        <TextBlock x:Uid="DetectNetworkButtonText" />
                                    </StackPanel>
                                </Button>

                                <Button
                                    x:Uid="ConnectPeerButton"
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    Margin="4"
                                    Command="{x:Bind ViewModel.ConnectToPeerCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="🔗" />
                                        <TextBlock x:Uid="ConnectPeerButtonText" />
                                    </StackPanel>
                                </Button>

                                <Button
                                    x:Uid="RefreshButton"
                                    Grid.Row="0"
                                    Grid.Column="2"
                                    Margin="4"
                                    Command="{x:Bind ViewModel.RefreshCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="🔄" />
                                        <TextBlock x:Uid="RefreshButtonText" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!--  网络状态 / Network Status  -->
                    <Border
                        x:Uid="NetworkStatusCard"
                        Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel Spacing="12">
                            <TextBlock
                                x:Uid="NetworkStatusTitle"
                                FontSize="18"
                                FontWeight="SemiBold" />

                            <TextBlock x:Uid="NetworkStatusTextBlock" FontSize="14" Text="{x:Bind ViewModel.NetworkStatusText, Mode=OneWay}" />

                            <TextBlock>
                                <Run x:Uid="NetworkQualityLabelRun" />
                                <Run FontWeight="Bold" Text="{x:Bind ViewModel.NetworkQualityText, Mode=OneWay}" />
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!--  最近活动 / Recent Activities  -->
                    <Border
                        x:Uid="RecentActivitiesCard"
                        Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel Spacing="12">
                            <TextBlock
                                x:Uid="RecentActivitiesTitle"
                                FontSize="18"
                                FontWeight="SemiBold" />

                            <ListView
                                x:Uid="RecentActivitiesList"
                                MaxHeight="200"
                                ItemsSource="{x:Bind ViewModel.RecentActivities, Mode=OneWay}"
                                ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <TextBlock
                                            Margin="0,2"
                                            FontSize="12"
                                            Text="{Binding}"
                                            TextWrapping="Wrap" />
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!--  网络状态页面 / Network Status Page  -->
            <Grid x:Name="NetworkContent" x:Uid="NetworkContent">
                <TextBlock
                    x:Uid="NetworkPagePlaceholder"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="24"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </Grid>

            <!--  节点列表页面 / Peer List Page  -->
            <Grid x:Name="PeerContent" x:Uid="PeerContent">
                <TextBlock
                    x:Uid="PeerPagePlaceholder"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="24"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </Grid>

            <!--  文件传输页面 / File Transfer Page  -->
            <Grid x:Name="TransferContent" x:Uid="TransferContent">
                <TextBlock
                    x:Uid="TransferPagePlaceholder"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="24"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </Grid>

            <!--  设置页面 / Settings Page  -->
            <Grid x:Name="SettingsContent" x:Uid="SettingsContent">
                <TextBlock
                    x:Uid="SettingsPagePlaceholder"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="24"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </Grid>
        </Grid>
    </Grid>
</Page>
