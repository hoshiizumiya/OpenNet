<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="OpenNet.Pages.RSSPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="using:OpenNet.ViewModels"
    NavigationCacheMode="Required"
    mc:Ignorable="d">

    <Grid Padding="24" Background="{ThemeResource LayerFillColorDefaultBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition
                Width="300"
                MinWidth="250"
                MaxWidth="400" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  Header  -->
        <StackPanel
            Grid.Row="0"
            Grid.ColumnSpan="2"
            Margin="0,0,0,16">
            <TextBlock
                x:Uid="RSSPageTitle"
                FontSize="28"
                FontWeight="SemiBold"
                Text="RSS Subscriptions" />
            <TextBlock
                x:Uid="RSSPageSubtitle"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="Subscribe to torrent RSS feeds for automatic downloads" />
        </StackPanel>

        <!--  Feed List Panel  -->
        <Grid
            Grid.Row="1"
            Grid.Column="0"
            Margin="0,0,16,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  Feed List Header  -->
            <Grid Grid.Row="0" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    x:Uid="RSSFeedsHeader"
                    VerticalAlignment="Center"
                    FontWeight="SemiBold"
                    Text="Feeds" />
                <StackPanel
                    Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="4">
                    <Button
                        x:Name="AddFeedButton"
                        Padding="8"
                        Click="AddFeedButton_Click"
                        ToolTipService.ToolTip="Add new feed">
                        <FontIcon FontSize="14" Glyph="&#xE710;" />
                    </Button>
                    <Button
                        Padding="8"
                        Click="RefreshAllButton_Click"
                        ToolTipService.ToolTip="Refresh all feeds">
                        <FontIcon FontSize="14" Glyph="&#xE72C;" />
                    </Button>
                </StackPanel>
            </Grid>

            <!--  Feed List  -->
            <ListView
                x:Name="FeedListView"
                Grid.Row="1"
                ItemsSource="{x:Bind ViewModel.Feeds, Mode=OneWay}"
                SelectedItem="{x:Bind ViewModel.SelectedFeed, Mode=TwoWay}"
                SelectionMode="Single">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="viewmodels:RSSFeedViewModel">
                        <Grid Padding="8" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock
                                    FontWeight="SemiBold"
                                    Text="{x:Bind Title, Mode=OneWay}"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    FontSize="12"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{x:Bind Url, Mode=OneWay}"
                                    TextTrimming="CharacterEllipsis" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}">
                                        <Run Text="{x:Bind ItemCount, Mode=OneWay}" />
                                        <Run x:Uid="RSSItemsLabel" Text="items" />
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>
                            <ToggleSwitch
                                Grid.Column="1"
                                IsOn="{x:Bind Enabled, Mode=TwoWay}"
                                OffContent=""
                                OnContent="" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!--  Feed Items Panel  -->
        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  Items Header  -->
            <Grid Grid.Row="0" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.SelectedFeed.Title, Mode=OneWay, FallbackValue='Select a feed'}" />
                    <TextBlock
                        FontSize="12"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{x:Bind ViewModel.SelectedFeed.LastUpdated, Mode=OneWay, FallbackValue=''}" />
                </StackPanel>
                <StackPanel
                    Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="4">
                    <Button
                        Padding="8"
                        Click="RefreshFeedButton_Click"
                        IsEnabled="{x:Bind ViewModel.HasSelectedFeed, Mode=OneWay}"
                        ToolTipService.ToolTip="Refresh this feed">
                        <FontIcon FontSize="14" Glyph="&#xE72C;" />
                    </Button>
                    <Button
                        Padding="8"
                        Click="FeedSettingsButton_Click"
                        IsEnabled="{x:Bind ViewModel.HasSelectedFeed, Mode=OneWay}"
                        ToolTipService.ToolTip="Feed settings">
                        <FontIcon FontSize="14" Glyph="&#xE713;" />
                    </Button>
                    <Button
                        Padding="8"
                        Click="RemoveFeedButton_Click"
                        IsEnabled="{x:Bind ViewModel.HasSelectedFeed, Mode=OneWay}"
                        ToolTipService.ToolTip="Remove feed">
                        <FontIcon FontSize="14" Glyph="&#xE74D;" />
                    </Button>
                </StackPanel>
            </Grid>

            <!--  Items List  -->
            <ListView
                x:Name="ItemsListView"
                Grid.Row="1"
                ItemsSource="{x:Bind ViewModel.SelectedFeed.Items, Mode=OneWay}"
                SelectedItem="{x:Bind ViewModel.SelectedItem, Mode=TwoWay}"
                SelectionMode="Single">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="viewmodels:RSSItemViewModel">
                        <Grid Padding="12" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock
                                    FontWeight="SemiBold"
                                    MaxLines="2"
                                    Text="{x:Bind Title}"
                                    TextWrapping="Wrap" />
                                <StackPanel
                                    Margin="0,4,0,0"
                                    Orientation="Horizontal"
                                    Spacing="12">
                                    <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                        <Run Text="{x:Bind PubDate}" />
                                    </TextBlock>
                                    <TextBlock
                                        FontSize="12"
                                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                        Text="{x:Bind FileSize}" />
                                    <TextBlock
                                        FontSize="12"
                                        Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                        Text="{x:Bind Category}" />
                                </StackPanel>
                            </StackPanel>
                            <Button
                                Grid.Column="1"
                                Padding="8"
                                Click="DownloadItemButton_Click"
                                Tag="{x:Bind}"
                                ToolTipService.ToolTip="Download">
                                <FontIcon
                                    FontSize="14"
                                    Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                    Glyph="&#xE896;" />
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!--  Status Bar  -->
        <Grid
            Grid.Row="2"
            Grid.ColumnSpan="2"
            Padding="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <ProgressRing
                x:Name="LoadingRing"
                Width="16"
                Height="16"
                Margin="0,0,8,0"
                IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />
            <TextBlock
                Grid.Column="1"
                VerticalAlignment="Center"
                FontSize="12"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" />
        </Grid>
    </Grid>
</Page>