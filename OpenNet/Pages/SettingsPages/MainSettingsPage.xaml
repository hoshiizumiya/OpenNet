<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="OpenNet.Pages.SettingsPages.MainSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:OpenNet.Pages.SettingsPages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.Resources>
            <x:Double x:Key="BreadcrumbBarChevronFontSize">20</x:Double>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <NavigationView
            x:Name="SettingsNavView"
            Grid.Row="0"
            Grid.Column="0"
            Grid.ColumnSpan="3"
            CompactPaneLength="70"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            OpenPaneLength="200"
            PaneDisplayMode="Left"
            SelectionChanged="SettingsNavView_SelectionChanged">
            <NavigationView.Header>
                <BreadcrumbBar
                    x:Name="MainSettingsPageBar"
                    Margin="0,-12,0,0"
                    x:FieldModifier="Public"
                    ItemClicked="SettingsBar_ItemClicked">
                    <BreadcrumbBar.ItemTemplate>
                        <DataTemplate x:DataType="local:Folder">
                            <TextBlock
                                Height="60"
                                Margin="10,0"
                                FontSize="40"
                                Text="{x:Bind Name}" />
                        </DataTemplate>
                    </BreadcrumbBar.ItemTemplate>
                </BreadcrumbBar>
            </NavigationView.Header>
            
            <NavigationView.MenuItems>
                <NavigationViewItem
                    x:Name="GeneralNavItem"
                    Content="General"
                    Icon="Setting"
                    Tag="general">
                    <NavigationViewItem.InfoBadge>
                        <InfoBadge />
                    </NavigationViewItem.InfoBadge>
                </NavigationViewItem>

                <NavigationViewItemSeparator />

                <NavigationViewItem
                    x:Name="NetworkNavItem"
                    Content="Network"
                    Tag="network">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE968;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem
                    x:Name="SerialPortNavItem"
                    Content="Serial Port"
                    Tag="serialport">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8CB;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem
                    x:Name="DownloadFlashNavItem"
                    Content="Download Flash"
                    Tag="downloadflash">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xEC59;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItemSeparator />

                <NavigationViewItem
                    x:Name="AboutNavItem"
                    Content="About"
                    Tag="about">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE946;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <Frame x:Name="SettingsFrame" x:FieldModifier="Public">
                <Frame.ContentTransitions>
                    <TransitionCollection>
                        <NavigationThemeTransition />
                    </TransitionCollection>
                </Frame.ContentTransitions>
            </Frame>
        </NavigationView>
    </Grid>
</Page>
