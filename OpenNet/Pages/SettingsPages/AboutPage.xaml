<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="OpenNet.Pages.SettingsPages.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:essential="using:WinUI3Package"
    xmlns:local="using:OpenNet.Pages.SettingsPages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    NavigationCacheMode="Disabled"
    mc:Ignorable="d">
    <!--  Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"  -->

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <BitmapImage x:Key="LogoImage" UriSource="ms-appx:///Assets/AppIcons/Square44x44Logo.altform-unplated_targetsize-256.png" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <BitmapImage x:Key="LogoImage" UriSource="ms-appx:///Assets/AppIcons/Square44x44Logo.altform-unplated_targetsize-256.png" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Page.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="60" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="60" />
        </Grid.ColumnDefinitions>

        <ScrollViewer
            Grid.Row="0"
            Grid.Column="1"
            Grid.ColumnSpan="2">
            <StackPanel Margin="0,0,60,0">
                <StackPanel.Resources>
                    <Style TargetType="Expander">
                        <Setter Property="HorizontalAlignment" Value="Stretch" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                </StackPanel.Resources>

                <StackPanel>
                    <Border
                        x:Name="CdhBorder"
                        Width="180"
                        Height="180"
                        Margin="0,6"
                        HorizontalAlignment="Left"
                        CornerRadius="4">
                        <Image
                            HorizontalAlignment="Center"
                            Source="ms-appx:///Assets/AppIcons/StoreLogo.scale-400.png"
                            Stretch="UniformToFill" />
                    </Border>

                    <StackPanel.Transitions>
                        <TransitionCollection>
                            <RepositionThemeTransition />
                        </TransitionCollection>
                    </StackPanel.Transitions>
                </StackPanel>

                <StackPanel>
                    <TextBlock Margin="0,12,0,0" Text="" />
                    <TextBlock Margin="0" Text="About" />

                    <essential:SettingsExpander
                        Margin="0,2,0,3"
                        Description="© 2026 Millennium-Science-Technology-R-D-Inst"
                        Header="OpenNet For Windows 11"
                        IsExpanded="False">
                        <essential:SettingsExpander.HeaderIcon>
                            <BitmapIcon ShowAsMonochrome="False" UriSource="ms-appx:///Assets/AppIcons/Square44x44Logo.altform-unplated_targetsize-256.png" />
                        </essential:SettingsExpander.HeaderIcon>

                        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                            <TextBlock HorizontalTextAlignment="Right" Text="Version : " />
                            <!--  未实现  -->
                            <!--<TextBlock HorizontalTextAlignment="Right" Text="{x:Bind}" />-->
                        </StackPanel>

                        <essential:SettingsExpander.Items>
                            <essential:SettingsCard ContentAlignment="Left">
                                <StackPanel Orientation="Vertical">
                                    <TextBlock
                                        Margin="0,3,10,1"
                                        HorizontalAlignment="Left"
                                        FontSize="14"
                                        FontWeight="Thin"
                                        Text="Dependencies &amp; References" />
                                    <HyperlinkButton
                                        Margin="-12,0,0,0"
                                        HorizontalAlignment="Left"
                                        Content="Windows App SDK"
                                        NavigateUri="https://aka.ms/windowsappsdk" />
                                    <HyperlinkButton
                                        Margin="-12,0,0,0"
                                        HorizontalAlignment="Left"
                                        Content="Windows UI Library"
                                        NavigateUri="https://github.com/microsoft/microsoft-ui-xaml" />
                                    <HyperlinkButton
                                        Margin="-12,0,0,0"
                                        HorizontalAlignment="Left"
                                        Content="Sample-Windows-CppWinRT"
                                        NavigateUri="https://github.com/CommunityToolkit/Sample-Windows-CppWinRT" />
                                    <HyperlinkButton
                                        Margin="-12,0,0,0"
                                        HorizontalAlignment="Left"
                                        Content="C++/WinRT"
                                        NavigateUri="https://github.com/microsoft/cppwinrt" />
                                    <HyperlinkButton
                                        Margin="-12,0,0,0"
                                        HorizontalAlignment="Left"
                                        Content="WinUI Essentials"
                                        NavigateUri="https://github.com/HO-COOH/WinUIEssentials" />
                                    <HyperlinkButton
                                        Margin="-12,0,0,0"
                                        HorizontalAlignment="Left"
                                        Content="libtorrent"
                                        NavigateUri="https://github.com/arvidn/libtorrent" />

                                    <StackPanel.ChildrenTransitions>
                                        <TransitionCollection>
                                            <EntranceThemeTransition FromVerticalOffset="100" IsStaggeringEnabled="True" />
                                            <RepositionThemeTransition IsStaggeringEnabled="False" />
                                        </TransitionCollection>
                                    </StackPanel.ChildrenTransitions>
                                </StackPanel>
                            </essential:SettingsCard>
                            <essential:SettingsCard HorizontalContentAlignment="Left" ContentAlignment="Left">
                                <StackPanel Orientation="Vertical">
                                    <TextBlock
                                        Margin="0,0,0,0"
                                        Text="THIS CODE AND INFORMATION IS PROVIDED ‘AS IS’ WITHOUT WARRANTY OF ANY KIND, EITHER EXPRESSED OR IMPLIED, INCLUDING BUT NOT LIMITED TO THE IMPLIED WARRANTIES OF MERCHANTABILITY AND/OR FITNESS FOR A PARTICULAR PURPOSE."
                                        TextWrapping="Wrap" />
                                    <HyperlinkButton
                                        Margin="-12,0,0,0"
                                        Content="License &amp; Source"
                                        NavigateUri="https://github.com/hoshiizumiya/OpenNet" />

                                    <StackPanel.ChildrenTransitions>
                                        <TransitionCollection>
                                            <EntranceThemeTransition FromVerticalOffset="100" IsStaggeringEnabled="True" />
                                            <RepositionThemeTransition IsStaggeringEnabled="False" />
                                        </TransitionCollection>
                                    </StackPanel.ChildrenTransitions>
                                </StackPanel>
                            </essential:SettingsCard>
                        </essential:SettingsExpander.Items>
                    </essential:SettingsExpander>

                    <essential:SettingsExpander
                        Margin="0,2,0,3"
                        Description="List of Producers / Special Thanks"
                        Header="FairingStudio"
                        IsExpanded="True">
                        <essential:SettingsExpander.Resources>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontSize" Value="18" />
                            </Style>
                        </essential:SettingsExpander.Resources>
                        <essential:SettingsExpander.HeaderIcon>
                            <ImageIcon Source="{ThemeResource LogoImage}" />
                        </essential:SettingsExpander.HeaderIcon>
                        <essential:SettingsExpander.Items>
                            <essential:SettingsCard ContentAlignment="Left">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Orientation="Vertical">
                                        <TextBlock
                                            Margin="0,6,0,1"
                                            HorizontalAlignment="Right"
                                            TextAlignment="Right">
                                            <Run
                                                FontFamily="/Assets/Fonts/GeosansLight.ttf#GeosansLight"
                                                FontWeight="Normal"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Text="Production / Visual Design" />
                                            <LineBreak />
                                            <Run
                                                FontFamily="/Assets/Fonts/GeosansLight.ttf#GeosansLight"
                                                FontSize="22"
                                                FontWeight="Black"
                                                Text="Hoshiizumiya" />
                                            <LineBreak /><LineBreak />
                                            <Run
                                                FontFamily="/Assets/Fonts/GeosansLight.ttf#GeosansLight"
                                                FontWeight="Normal"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Text="Programming Director" />
                                            <LineBreak />
                                            <Run
                                                FontFamily="/Assets/Fonts/GeosansLight.ttf#GeosansLight"
                                                FontSize="22"
                                                FontWeight="Black"
                                                Text="Hoshiizumiya" />
                                            <LineBreak />
                                            <Run
                                                FontFamily="/Assets/Fonts/GeosansLight.ttf#GeosansLight"
                                                FontSize="22"
                                                FontWeight="Black"
                                                Text="AlexAdas" />
                                            <LineBreak /><LineBreak />
                                            <Run
                                                FontFamily="/Assets/Fonts/GeosansLight.ttf#GeosansLight"
                                                FontWeight="Normal"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Text="AI Programming Assistant / Consultant" />
                                            <LineBreak />
                                            <Run
                                                FontFamily="/Assets/Fonts/GeosansLight.ttf#GeosansLight"
                                                FontSize="22"
                                                FontWeight="Black"
                                                Text="Chat-GPT" />
                                            <LineBreak />
                                            <Run
                                                FontFamily="/Assets/Fonts/GeosansLight.ttf#GeosansLight"
                                                FontSize="22"
                                                FontWeight="Black"
                                                Text="Github Copilot" />
                                            <LineBreak />
                                            <LineBreak />
                                            <Run
                                                FontFamily="/Assets/Fonts/GeosansLight.ttf#GeosansLight"
                                                FontWeight="Normal"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Text="Software Framework" />
                                            <LineBreak />
                                            <Run
                                                FontFamily="/Assets/Fonts/GeosansLight.ttf#GeosansLight"
                                                FontSize="22"
                                                FontWeight="Black"
                                                Text="AlexAdas" />
                                            <LineBreak />
                                            <Run FontWeight="Medium" Text="ㅤㅤㅤㅤ" />
                                        </TextBlock>

                                        <!--<StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                            <TextBlock
                                                Margin="0,1,0,1"
                                                HorizontalAlignment="Right"
                                                CenterPoint="10,12,0"
                                                FontWeight="Medium"
                                                Rotation="0"
                                                Text="都" />
                                            <TextBlock
                                                Margin="0,1,1,1"
                                                HorizontalAlignment="Right"
                                                CenterPoint="10,14,0"
                                                FontWeight="Medium"
                                                Rotation="90"
                                                Text="筑" />
                                            <TextBlock
                                                Margin="1,-2,0,1"
                                                HorizontalAlignment="Right"
                                                CenterPoint="10,14,0"
                                                FontWeight="Medium"
                                                Rotation="180"
                                                Text="は" />
                                            <TextBlock
                                                Margin="0,1,1,1"
                                                HorizontalAlignment="Right"
                                                CenterPoint="10,14,0"
                                                FontWeight="Medium"
                                                Rotation="0"
                                                Text="る" />
                                            <TextBlock
                                                Margin="-4,1,0,1"
                                                HorizontalAlignment="Right"
                                                CenterPoint="10,14,0"
                                                FontWeight="Medium"
                                                Rotation="90"
                                                Text="か" />
                                        </StackPanel>-->

                                        <!--<TextBlock Text="Software Tester" FontSize="14" FontWeight="Thin" HorizontalAlignment="Right" Margin="0,6,0,1"/>
                                    <TextBlock Text="" FontWeight="Medium" HorizontalAlignment="Right" Margin="0,1,0,1"/>-->

                                        <TextBlock
                                            Margin="0,12,0,1"
                                            HorizontalAlignment="Right"
                                            TextAlignment="Right">
                                            <Run
                                                FontFamily="/Assets/Fonts/GeosansLight.ttf#GeosansLight"
                                                FontWeight="Normal"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Text="Special Thanks" />
                                            <LineBreak />
                                            <Run FontWeight="Medium" Text="AlexAdas" />
                                            <LineBreak />
                                            <Run FontWeight="Medium" Text="HO-COOH" />
                                            <LineBreak />
                                            <Run
                                                FontFamily="/Assets/Fonts/GeosansLight.ttf#GeosansLight"
                                                FontSize="22"
                                                FontWeight="Black"
                                                Text="You!" />
                                            <LineBreak />
                                        </TextBlock>
                                        <StackPanel.ChildrenTransitions>
                                            <TransitionCollection>
                                                <EntranceThemeTransition FromVerticalOffset="10" IsStaggeringEnabled="True" />
                                                <RepositionThemeTransition IsStaggeringEnabled="False" />
                                            </TransitionCollection>
                                        </StackPanel.ChildrenTransitions>
                                    </StackPanel>


                                </Grid>
                            </essential:SettingsCard>

                            <essential:SettingsCard HorizontalContentAlignment="Left" ContentAlignment="Left">
                                <StackPanel Orientation="Vertical">
                                    <!--<HyperlinkButton
                                        Margin="-12,0,0,0"
                                        Content="Visit Our Studio Website"
                                        NavigateUri="" />-->
                                    <HyperlinkButton
                                        Margin="-12,0,0,0"
                                        Content="Help &amp; Feedback"
                                        NavigateUri="https://github.com/hoshiizumiya/OpenNet/issues" />

                                    <StackPanel.ChildrenTransitions>
                                        <TransitionCollection>
                                            <EntranceThemeTransition FromVerticalOffset="100" IsStaggeringEnabled="True" />
                                            <RepositionThemeTransition IsStaggeringEnabled="False" />
                                        </TransitionCollection>
                                    </StackPanel.ChildrenTransitions>
                                </StackPanel>
                            </essential:SettingsCard>
                        </essential:SettingsExpander.Items>
                    </essential:SettingsExpander>

                    <essential:SettingsExpander
                        Margin="0,3,0,3"
                        Description="OpenNet for WinUI3"
                        Header="OpenNet in Github"
                        IsExpanded="True">
                        <essential:SettingsExpander.HeaderIcon>
                            <FontIcon Glyph="&#xE943;" />
                        </essential:SettingsExpander.HeaderIcon>
                        <essential:SettingsExpander.Items>
                            <essential:SettingsCard HorizontalContentAlignment="Left" ContentAlignment="Left">
                                <StackPanel Orientation="Vertical">
                                    <HyperlinkButton
                                        Margin="-12,0,0,0"
                                        Content="Join the project on Github"
                                        NavigateUri="https://github.com/hoshiizumiya/OpenNet" />
                                </StackPanel>
                            </essential:SettingsCard>
                        </essential:SettingsExpander.Items>
                    </essential:SettingsExpander>

                    <TextBlock Margin="0,12,0,0" Text="" />
                    <StackPanel.ChildrenTransitions>
                        <TransitionCollection>
                            <EntranceThemeTransition FromVerticalOffset="100" IsStaggeringEnabled="True" />
                            <RepositionThemeTransition IsStaggeringEnabled="False" />
                        </TransitionCollection>
                    </StackPanel.ChildrenTransitions>
                </StackPanel>

                <StackPanel.ChildrenTransitions>
                    <TransitionCollection>
                        <EntranceThemeTransition FromVerticalOffset="100" IsStaggeringEnabled="True" />
                        <RepositionThemeTransition IsStaggeringEnabled="False" />
                    </TransitionCollection>
                </StackPanel.ChildrenTransitions>
            </StackPanel>
        </ScrollViewer>
    </Grid>

</Page>
