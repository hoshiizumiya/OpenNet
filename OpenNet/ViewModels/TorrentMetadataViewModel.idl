import "ViewModels/ObservableObject.idl";

namespace OpenNet.ViewModels
{
    // Represents a node in the torrent file tree (can be a file or folder)
    [default_interface]
    runtimeclass TorrentFileNodeViewModel : Microsoft.UI.Xaml.Data.INotifyPropertyChanged
    {
        TorrentFileNodeViewModel();

        // Node properties
        String Name;               // File or folder name
        String FullPath;           // Full relative path
        String SizeText;           // Formatted size string (e.g., "1.5 GB")
        Int64 SizeBytes;           // Raw size in bytes
        Boolean IsSelected;        // Whether this node is selected
        Boolean IsFolder;          // True if folder, false if file
        Boolean IsExpanded;        // For folders, whether expanded in UI
        Int32 FileIndex;           // File index (-1 for folders)
        Int32 Priority;            // Download priority (0-7, for files)
        String PriorityText{ get; };

        // Children (for folders)
        Windows.Foundation.Collections.IObservableVector<TorrentFileNodeViewModel> Children{ get; };
        Boolean HasChildren{ get; };
    }

    // Represents a single file in the torrent for UI binding (kept for backward compatibility)
    [default_interface]
    runtimeclass TorrentFileInfoViewModel : Microsoft.UI.Xaml.Data.INotifyPropertyChanged
    {
        TorrentFileInfoViewModel();

        // File properties
        String FileName;           // File name (last part of path)
        String FilePath;           // Full relative path
        String FileSize;           // Formatted size string (e.g., "1.5 GB")
        Int64 FileSizeBytes;       // Raw size in bytes
        Boolean IsSelected;        // Whether file is selected for download
        Int32 Priority;            // Download priority (0-7)
        Int32 FileIndex;           // Index in torrent file list

        // Display helpers
        String PriorityText{ get; };   // Human-readable priority
    }

    // Represents the complete torrent metadata for UI binding
    [default_interface]
    runtimeclass TorrentMetadataViewModel : Microsoft.UI.Xaml.Data.INotifyPropertyChanged
    {
        TorrentMetadataViewModel();

        // Torrent info
        String TorrentName;
        String InfoHash;
        String TotalSize;              // Formatted total size
        Int64 TotalSizeBytes;          // Raw total size in bytes
        String SelectedSize;           // Formatted selected files size
        Int64 SelectedSizeBytes{ get; };  // Raw selected size in bytes
        String Comment;
        String Creator;
        String CreationDate;
        Int32 PieceLength;
        Int32 NumPieces;
        Boolean IsPrivate;

        // File list (flat list for backward compatibility)
        Windows.Foundation.Collections.IObservableVector<TorrentFileInfoViewModel> Files{ get; };

        // Hierarchical file tree (for TreeView display)
        Windows.Foundation.Collections.IObservableVector<TorrentFileNodeViewModel> FileTree{ get; };

        Int32 TotalFileCount{ get; };
        Int32 SelectedFileCount{ get; };

        // Tracker list
        Windows.Foundation.Collections.IObservableVector<String> Trackers{ get; };

        // Download settings
        String SavePath;
        Boolean CreateSubfolder;
        Boolean StartImmediately;

        // Selection helpers
        void SelectAll();
        void DeselectAll();
        void SelectByExtension(String extension);
        void ToggleSelection(Int32 fileIndex);

        // Update selected size after selection changes
        void RefreshSelectedSize();

        // Sync tree node IsSelected states to the flat file list
        void SyncTreeToFlatList();

        // Sync flat file list IsSelected states to tree leaf nodes + update folders
        void SyncFlatListToTree();

        // Update folder checkbox states based on children (propagate child→parent)
        void UpdateFolderSelectionStates();
    }
}
