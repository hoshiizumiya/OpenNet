import "UI/Xaml/Media/Effects/Effects.idl";

namespace OpenNet.UI.Xaml.Media.Animations
{
    /// <summary>
    /// Base class for effect property animations.
    /// Provides a way to animate properties of IPipelineEffect instances.
    /// </summary>
    [default_interface]
    unsealed runtimeclass EffectAnimationBase : Microsoft.UI.Xaml.DependencyObject
    {
        /// <summary>
        /// Gets or sets the duration of the animation.
        /// </summary>
        Windows.Foundation.TimeSpan Duration;
        static Microsoft.UI.Xaml.DependencyProperty DurationProperty{ get; };

        /// <summary>
        /// Gets or sets the delay before the animation starts.
        /// </summary>
        Windows.Foundation.TimeSpan Delay;
        static Microsoft.UI.Xaml.DependencyProperty DelayProperty{ get; };
    }

    /// <summary>
    /// An animation that targets BlurEffect.Amount.
    /// </summary>
    [default_interface]
    runtimeclass BlurEffectAnimation : EffectAnimationBase
    {
        BlurEffectAnimation();

        OpenNet.UI.Xaml.Media.Effects.BlurEffect Target;
        Double From;
        Double To;

        static Microsoft.UI.Xaml.DependencyProperty TargetProperty{ get; };
        static Microsoft.UI.Xaml.DependencyProperty FromProperty{ get; };
        static Microsoft.UI.Xaml.DependencyProperty ToProperty{ get; };
    }

