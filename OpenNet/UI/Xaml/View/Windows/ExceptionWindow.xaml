<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="OpenNet.UI.Xaml.View.Windows.ExceptionWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:OpenNet.UI.Xaml.View.Windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <TitleBar
            x:Name="ExceptionWindowTitleBar"
            x:Uid="ViewWindowExceptionTitle"
            Title="We encountered some problems"
            Grid.Row="0"
            Height="32"
            Margin="12,0,0,0"
            FontSize="{StaticResource CaptionTextBlockFontSize}"
            IsBackButtonVisible="False"
            IsPaneToggleButtonVisible="False" />
        <Grid
            Grid.Row="1"
            Padding="16"
            Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
            RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0">
                <TextBlock
                    x:Uid="ViewWindowExceptionHeader"
                    Style="{StaticResource SubheaderTextBlockStyle}"
                    Text="An unrecoverable fatal error has occurred" />
                <TextBlock
                    Foreground="{ThemeResource SystemControlErrorTextForegroundBrush}"
                    IsTextSelectionEnabled="True"
                    Text="{x:Bind TraceId}" />
            </StackPanel>
            <TextBox
                x:Uid="ViewExceptionWindowStacktraceHeader"
                Grid.Row="1"
                AcceptsReturn="True"
                Header="Call Stack"
                IsReadOnly="True"
                ScrollViewer.HorizontalScrollBarVisibility="Auto"
                Text="{x:Bind Exception}" />
            <TextBox
                x:Uid="ViewExceptionWindowComment"
                Grid.Row="2"
                AcceptsReturn="True"
                Description="Clear, step-by-step descriptions will help us locate the issue faster"
                Header="What actions did you perform before the crash occurred?"
                ScrollViewer.HorizontalScrollBarVisibility="Auto"
                Text="{x:Bind Comment, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <StackPanel
                Grid.Row="3"
                HorizontalAlignment="Right"
                Orientation="Horizontal">
                <Button
                    x:Uid="ViewWindowExceptionClose"
                    Click="ViewWindowExceptionCloseButton_Click"
                    Content="Close" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
