<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="OpenNet.UI.Xaml.View.Pages.TaskFilesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="using:XamlToolkit.WinUI.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:interactivity="using:XamlToolkit.WinUI.Interactivity"
    xmlns:labs="using:XamlToolkit.Labs.WinUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:OpenNet.ViewModels"
    mc:Ignorable="d">

    <Grid Padding="0,8,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  File list  -->
        <ListView
            x:Name="FilesListView"
            Grid.Row="1"
            SelectionMode="None">
            <ListView.Header>
                <Border
                    Padding="8,4,0,4"
                    Background="{ThemeResource SolidBackgroundFillColorTertiaryBrush}"
                    CornerRadius="4">
                    <interactivity:Interaction.Behaviors>
                        <behaviors:StickyHeaderBehavior />
                    </interactivity:Interaction.Behaviors>
                    <labs:DataTable ColumnSpacing="16">
                        <labs:DataColumn x:Name="ColFileName" CanResize="True">
                            <TextBlock
                                x:Uid="FileHeader_Path"
                                FontWeight="SemiBold"
                                Text="File" />
                        </labs:DataColumn>
                        <labs:DataColumn x:Name="ColFileSize" CanResize="True">
                            <TextBlock
                                x:Uid="FileHeader_Size"
                                FontWeight="SemiBold"
                                Text="Size" />
                        </labs:DataColumn>
                        <labs:DataColumn x:Name="ColFileProgress" CanResize="True">
                            <TextBlock
                                x:Uid="FileHeader_Progress"
                                FontWeight="SemiBold"
                                Text="Progress" />
                        </labs:DataColumn>
                        <labs:DataColumn x:Name="ColFileDone" CanResize="True">
                            <TextBlock
                                x:Uid="FileHeader_Done"
                                FontWeight="SemiBold"
                                Text="Done" />
                        </labs:DataColumn>
                        <labs:DataColumn x:Name="ColFilePriority" CanResize="True">
                            <TextBlock
                                x:Uid="FileHeader_Priority"
                                FontWeight="SemiBold"
                                Text="Priority" />
                        </labs:DataColumn>
                    </labs:DataTable>
                </Border>
            </ListView.Header>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:FileDisplayItem">
                    <labs:DataRow HorizontalAlignment="Left">
                        <TextBlock
                            Text="{x:Bind Path}"
                            TextTrimming="CharacterEllipsis"
                            ToolTipService.ToolTip="{x:Bind Path}" />
                        <TextBlock Text="{x:Bind Size}" />
                        <ProgressBar
                            Margin="4,0"
                            VerticalAlignment="Center"
                            Maximum="100"
                            Value="{x:Bind ProgressValue}" />
                        <TextBlock Text="{x:Bind Done}" />
                        <ComboBox
                            MinWidth="80"
                            HorizontalAlignment="Stretch"
                            SelectedIndex="{x:Bind PriorityIndex, Mode=OneWay}"
                            SelectionChanged="FilePriority_SelectionChanged"
                            Tag="{x:Bind FileIndex}">
                            <ComboBoxItem x:Uid="FilePriority_Skip" Content="Skip" />
                            <ComboBoxItem x:Uid="FilePriority_Low" Content="Low" />
                            <ComboBoxItem x:Uid="FilePriority_Normal" Content="Normal" />
                            <ComboBoxItem x:Uid="FilePriority_High" Content="High" />
                        </ComboBox>
                    </labs:DataRow>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!--  Empty state  -->
        <TextBlock
            x:Name="EmptyStateText"
            x:Uid="FilesList_EmptyState"
            Grid.Row="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            Text="No file information available"
            Visibility="Collapsed" />
    </Grid>
</Page>
