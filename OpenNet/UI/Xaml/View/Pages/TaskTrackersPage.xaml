<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="OpenNet.UI.Xaml.View.Pages.TaskTrackersPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="using:XamlToolkit.WinUI.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:interactivity="using:XamlToolkit.WinUI.Interactivity"
    xmlns:labs="using:XamlToolkit.Labs.WinUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:OpenNet.ViewModels"
    mc:Ignorable="d">

    <Grid Padding="0,8,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Tracker list  -->
        <ListView
            x:Name="TrackersListView"
            Grid.Row="1"
            SelectionMode="None">
            <ListView.Header>
                <Border
                    Padding="8,4,0,4"
                    Background="{ThemeResource SolidBackgroundFillColorTertiaryBrush}"
                    CornerRadius="4">
                    <interactivity:Interaction.Behaviors>
                        <behaviors:StickyHeaderBehavior />
                    </interactivity:Interaction.Behaviors>
                    <labs:DataTable ColumnSpacing="16">
                        <labs:DataColumn x:Name="ColTrackerURL" CanResize="True">
                            <TextBlock
                                x:Uid="TrackerHeader_URL"
                                FontWeight="SemiBold"
                                Text="URL" />
                        </labs:DataColumn>
                        <labs:DataColumn x:Name="ColTrackerTier" CanResize="True">
                            <TextBlock
                                x:Uid="TrackerHeader_Tier"
                                FontWeight="SemiBold"
                                Text="Tier" />
                        </labs:DataColumn>
                        <labs:DataColumn x:Name="ColTrackerPeers" CanResize="True">
                            <TextBlock
                                x:Uid="TrackerHeader_Peers"
                                FontWeight="SemiBold"
                                Text="Peers" />
                        </labs:DataColumn>
                        <labs:DataColumn x:Name="ColTrackerStatus" CanResize="True">
                            <TextBlock
                                x:Uid="TrackerHeader_Status"
                                FontWeight="SemiBold"
                                Text="Status" />
                        </labs:DataColumn>
                        <labs:DataColumn x:Name="ColTrackerMessage" CanResize="True">
                            <TextBlock
                                x:Uid="TrackerHeader_Message"
                                FontWeight="SemiBold"
                                Text="Message" />
                        </labs:DataColumn>
                    </labs:DataTable>
                </Border>
            </ListView.Header>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:TrackerDisplayItem">
                    <labs:DataRow HorizontalAlignment="Left">
                        <TextBlock Text="{x:Bind URL}" TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{x:Bind Tier}" />
                        <TextBlock Text="{x:Bind Peers}" />
                        <TextBlock Text="{x:Bind Status}" />
                        <TextBlock Text="{x:Bind Message}" TextTrimming="CharacterEllipsis" />
                    </labs:DataRow>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!--  Empty state  -->
        <TextBlock
            x:Name="EmptyStateText"
            x:Uid="TrackersList_EmptyState"
            Grid.Row="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            Text="No trackers"
            Visibility="Collapsed" />
    </Grid>
</Page>
