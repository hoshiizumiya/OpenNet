<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="OpenNet.UI.Xaml.View.Pages.SettingsPages.ThemesSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:essential="using:WinUI3Package"
    xmlns:local="using:OpenNet.UI.Xaml.View.Pages.SettingsPages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Margin="24">

        <essential:SettingsCard
            x:Name="SoftPersonalization"
            x:Uid="SoftPersonalization"
            Margin="0,3,0,3"
            Description="A SettingsCard can be made clickable and you can leverage the Command property or Click event."
            Header=""
            IsClickEnabled="True">
            <essential:SettingsCard.HeaderIcon>
                <FontIcon FontSize="12"
                        Glyph="&#xE771;"/>
            </essential:SettingsCard.HeaderIcon>

        </essential:SettingsCard>

    </Grid>
</Page>
