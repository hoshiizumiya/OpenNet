<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="OpenNet.UI.Xaml.View.Pages.TasksPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="using:XamlToolkit.WinUI.Behaviors"
    xmlns:controls="using:XamlToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:essential="using:WinUI3Package"
    xmlns:interactivity="using:XamlToolkit.WinUI.Interactivity"
    xmlns:labs="using:XamlToolkit.Labs.WinUI"
    xmlns:local="using:OpenNet.UI.Xaml.View.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:speedgraph="using:OpenNet.Controls.SpeedGraph"
    xmlns:vm="using:OpenNet.ViewModels"
    x:Uid="TasksPageRoot"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <!--  SearchBox + CommandBar  -->
        <CommandBar
            Grid.Row="0"
            Margin="4,2,4,0"
            essential:CommandBarHelper.AcrylicWorkaround="True"
            CornerRadius="4"
            DefaultLabelPosition="Right">
            <AppBarButton
                x:Name="TaskNewButton"
                x:Uid="TaskNewButton"
                Icon="Add">
                <muxc:AppBarButton.Flyout>
                    <muxc:MenuFlyout Placement="Bottom">
                        <muxc:MenuFlyoutItem
                            x:Name="MenuItemAddFromLink"
                            x:Uid="TaskNewFromUrlButton"
                            Click="MenuItemAddFromLink_ClickAsync"
                            Icon="{essential:FontIcon FontFamily=Segoe UI Emoji,
                                                      Glyph=&#x1F9F2;}"
                            Text="From Magnet Link" />
                        <muxc:MenuFlyoutItem
                            x:Name="MenuItemAddFromFile"
                            x:Uid="TaskNewFromFileButton"
                            Click="MenuItemAddFromFile_ClickAsync"
                            Icon="{essential:FontIcon Glyph=&#xE8E5;}"
                            Text="From Bittorrent File" />
                        <muxc:MenuFlyoutSeparator />
                        <muxc:MenuFlyoutItem
                            x:Name="MenuItemAddFromHttp"
                            x:Uid="TaskNewFromHttpButton"
                            Click="MenuItemAddFromHttp_ClickAsync"
                            Icon="Link"
                            Text="HTTP Download" />
                    </muxc:MenuFlyout>
                </muxc:AppBarButton.Flyout>
            </AppBarButton>
            <AppBarButton
                x:Uid="TaskStartButton"
                Command="{x:Bind ViewModel.StartCommand}"
                Icon="Play" />
            <AppBarButton
                x:Uid="TaskPauseButton"
                Command="{x:Bind ViewModel.PauseCommand}"
                Icon="Pause" />
            <AppBarButton
                x:Uid="TaskDeleteButton"
                Command="{x:Bind ViewModel.DeleteCommand}"
                Icon="Delete" />
            <CommandBar.SecondaryCommands>
                <AppBarButton Icon="Setting" Label="Settings">
                    <AppBarButton.KeyboardAccelerators>
                        <KeyboardAccelerator Key="I" Modifiers="Control" />
                    </AppBarButton.KeyboardAccelerators>
                </AppBarButton>
            </CommandBar.SecondaryCommands>

        </CommandBar>

        <AutoSuggestBox
            x:Name="SearchBox"
            Grid.Row="0"
            Width="280"
            Margin="12,6"
            HorizontalAlignment="Left"
            essential:AutoSuggestBoxHelper.AcrylicWorkaround="True"
            PlaceholderText="Search"
            QueryIcon="Find"
            TextChanged="SearchBox_TextChanged" />

        <SplitView
            Grid.Row="1"
            Margin="4"
            CornerRadius="8"
            DisplayMode="Inline"
            IsPaneOpen="True"
            OpenPaneLength="50"
            PaneBackground="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}">
            <SplitView.Pane>
                <!--  左侧筛选导航 / Left-side filter navigation  -->
                <muxc:NavigationView
                    x:Name="FilterNavView"
                    essential:NavigationViewHelper.AcrylicWorkaround="True"
                    IsBackButtonVisible="Collapsed"
                    IsPaneToggleButtonVisible="False"
                    IsSettingsVisible="False"
                    PaneDisplayMode="LeftCompact"
                    SelectionChanged="FilterNavView_SelectionChanged">
                    <muxc:NavigationView.MenuItems>
                        <muxc:NavigationViewItem
                            x:Uid="FilterNavViewAllTasks"
                            Icon="ViewAll"
                            IsSelected="True"
                            Tag="AllTasks" />
                        <muxc:NavigationViewItem
                            x:Uid="FilterNavViewDownloading"
                            Icon="Download"
                            Tag="Downloading" />
                        <muxc:NavigationViewItem
                            x:Uid="FilterNavViewCompleted"
                            Icon="Accept"
                            Tag="Completed" />
                        <muxc:NavigationViewItem
                            x:Uid="FilterNavViewFailed"
                            Icon="Cancel"
                            Tag="Failed" />
                    </muxc:NavigationView.MenuItems>
                </muxc:NavigationView>
            </SplitView.Pane>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!--  Tasks List  -->
                <ListView
                    x:Name="TasksList"
                    Grid.Row="0"
                    ItemsSource="{x:Bind ViewModel.FilteredTasks, Mode=OneWay}"
                    RightTapped="TasksList_RightTapped"
                    SelectionChanged="TasksList_SelectionChanged"
                    SelectionMode="Single">
                    <ListView.ItemContainerStyle>
                        <Style BasedOn="{StaticResource DefaultListViewItemStyle}" TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.Header>
                        <Border
                            Padding="8,4,0,4"
                            Background="{ThemeResource SolidBackgroundFillColorTertiaryBrush}"
                            CornerRadius="4">
                            <interactivity:Interaction.Behaviors>
                                <behaviors:StickyHeaderBehavior />
                            </interactivity:Interaction.Behaviors>
                            <labs:DataTable ColumnSpacing="16" Loaded="DataTable_Loaded">
                                <labs:DataColumn
                                    x:Name="ColName"
                                    CanResize="True"
                                    Tag="Name">
                                    <TextBlock x:Uid="Header_TaskName" FontWeight="SemiBold" />
                                </labs:DataColumn>
                                <labs:DataColumn
                                    x:Name="ColSize"
                                    CanResize="True"
                                    Tag="Size">
                                    <TextBlock
                                        x:Uid="Header_Size"
                                        FontWeight="SemiBold"
                                        Text="Size" />
                                </labs:DataColumn>
                                <labs:DataColumn
                                    x:Name="ColProgress"
                                    CanResize="True"
                                    Tag="Progress">
                                    <TextBlock
                                        x:Uid="Header_Progress"
                                        FontWeight="SemiBold"
                                        Text="Progress" />
                                </labs:DataColumn>
                                <labs:DataColumn
                                    x:Name="ColDLRate"
                                    CanResize="True"
                                    Tag="DLRate">
                                    <TextBlock
                                        x:Uid="Header_DLRate"
                                        FontWeight="SemiBold"
                                        Text="DL Rate" />
                                </labs:DataColumn>
                                <labs:DataColumn
                                    x:Name="ColULRate"
                                    CanResize="True"
                                    Tag="ULRate">
                                    <TextBlock
                                        x:Uid="Header_ULRate"
                                        FontWeight="SemiBold"
                                        Text="UL Rate" />
                                </labs:DataColumn>
                                <labs:DataColumn
                                    x:Name="ColRemaining"
                                    CanResize="True"
                                    Tag="Remaining">
                                    <TextBlock
                                        x:Uid="Header_Remaining"
                                        FontWeight="SemiBold"
                                        Text="Remaining" />
                                </labs:DataColumn>
                                <labs:DataColumn
                                    x:Name="ColAddDate"
                                    CanResize="True"
                                    Tag="AddDate">
                                    <TextBlock
                                        x:Uid="Header_AddDate"
                                        FontWeight="SemiBold"
                                        Text="Add Date" />
                                </labs:DataColumn>
                            </labs:DataTable>
                        </Border>
                    </ListView.Header>
                    <ListView.ContextFlyout>
                        <MenuFlyout>
                            <MenuFlyoutItem
                                x:Name="RenameTaskMenuItem"
                                x:Uid="RenameTaskMenuItem"
                                Click="RenameTaskMenuItem_ClickAsync"
                                Icon="Rename"
                                Text="Rename" />
                            <MenuFlyoutItem
                                x:Name="MoveTaskMenuItem"
                                x:Uid="MoveTaskMenuItem"
                                Click="MoveTaskMenuItem_Click"
                                Icon="MoveToFolder"
                                Text="Move to..." />
                            <MenuFlyoutItem
                                x:Name="OpenTaskLocationMenuItem"
                                x:Uid="OpenTaskLocationMenuItem"
                                Click="OpenTaskLocationMenuItem_Click"
                                Icon="OpenFile"
                                Text="Open Location" />
                            <MenuFlyoutSeparator />
                            <MenuFlyoutItem
                                x:Name="PropertiesMenuItem"
                                x:Uid="PropertiesMenuItem"
                                Click="PropertiesMenuItem_Click"
                                Icon="More"
                                Text="Properties" />
                        </MenuFlyout>
                    </ListView.ContextFlyout>
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <muxc:ItemsStackPanel Orientation="Vertical" />
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:TaskViewModel">
                            <!--  We set HorizontalAlignment to Left here as we're not stretching our content with a star column  -->
                            <labs:DataRow HorizontalAlignment="Left">
                                <TextBlock
                                    Margin="12,0,8,0"
                                    IsTextSelectionEnabled="True"
                                    Text="{x:Bind Name, Mode=OneWay}"
                                    TextWrapping="Wrap" />
                                <TextBlock Text="{x:Bind Size, Mode=OneWay}" />
                                <TextBlock Text="{x:Bind Progress, Mode=OneWay}" />
                                <TextBlock Text="{x:Bind DownloadRate, Mode=OneWay}" />
                                <TextBlock Text="{x:Bind UploadRate, Mode=OneWay}" />
                                <TextBlock Text="{x:Bind Remaining, Mode=OneWay}" />
                                <TextBlock Text="{x:Bind AddDate, Mode=OneWay}" />
                            </labs:DataRow>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!--  下方多标签 + SpeedGraph  -->
                <muxc:SelectorBar
                    x:Name="Task_SelectBar"
                    Grid.Row="1"
                    SelectionChanged="Task_SelectBar_SelectionChanged">
                    <muxc:SelectorBarItem
                        x:Name="SummaryContent"
                        x:Uid="Task_SummaryContent"
                        IsSelected="True" />
                    <muxc:SelectorBarItem x:Name="PeersList" x:Uid="Task_PeersList" />
                    <muxc:SelectorBarItem x:Name="TrackersList" x:Uid="Task_TrackersList" />
                    <muxc:SelectorBarItem x:Name="FilesList" x:Uid="Task_FilesList" />
                </muxc:SelectorBar>

                <Frame
                    x:Name="ContentFrame"
                    Grid.Row="1"
                    Margin="0,42,0,0"
                    IsNavigationStackEnabled="False" />

                <!--  上下可调分隔条（XamlToolkit GridSplitter）  -->
                <controls:GridSplitter
                    Grid.Row="1"
                    Height="12"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Top"
                    PointerReleased="GridSplitter_PointerReleased"
                    ResizeBehavior="BasedOnAlignment"
                    ResizeDirection="Rows">
                    <controls:GridSplitter.RenderTransform>
                        <TranslateTransform Y="-7" />
                    </controls:GridSplitter.RenderTransform>
                </controls:GridSplitter>

            </Grid>
        </SplitView>
    </Grid>
</Page>
