<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="OpenNet.UI.Xaml.View.Pages.TorrentCheckGeneralPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:OpenNet.UI.Xaml.View.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid
        Padding="16,0,16,16"
        VerticalAlignment="Stretch"
        RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Scrollable content  -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12">
                <Border
                    Padding="12"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    CornerRadius="4">
                    <StackPanel Spacing="8">
                        <TextBlock x:Uid="AddMagnet_SaveLabel" FontWeight="SemiBold" />
                        <Grid
                            ColumnDefinitions="Auto,*,Auto,Auto"
                            ColumnSpacing="8"
                            RowDefinitions="Auto,Auto,Auto"
                            RowSpacing="8">
                            <TextBlock
                                x:Uid="TorrentCheckGeneralPage_SavePathLabel"
                                Margin="0,0,4,0"
                                VerticalAlignment="Center" />
                            <!--
                                QuerySubmitted="Control2_QuerySubmitted"
                                SuggestionChosen="Control2_SuggestionChosen"
                                TextChanged="Control2_TextChanged"
                            -->

                            <AutoSuggestBox
                                x:Name="TorrentCheckGeneralPageSavePath"
                                x:Uid="TorrentCheckGeneralPageSavePath"
                                Grid.Column="1">
                                <AutoSuggestBox.QueryIcon>
                                    <FontIcon HorizontalAlignment="Center" Glyph="&#xE70D;" />
                                </AutoSuggestBox.QueryIcon>
                            </AutoSuggestBox>

                            <!--  pick a folder  -->
                            <Button
                                x:Uid="TorrentCheckGeneralPage_FolderPickerButton"
                                Grid.Column="2"
                                MinWidth="36"
                                Click="TorrentCheckGeneralPageFolderPicker_Click">
                                <Button.Content>
                                    <FontIcon Glyph="&#xEC50;" />
                                </Button.Content>
                            </Button>

                            <TextBlock
                                x:Uid="TorrentCheckGeneralPage_FileNameLabel"
                                Grid.Row="1"
                                Margin="0,0,4,0"
                                VerticalAlignment="Center" />
                            <TextBox
                                x:Uid="TorrentCheckGeneralPage_FileNameTextBox"
                                Grid.Row="1"
                                Grid.Column="1"
                                Grid.ColumnSpan="3" />

                            <CheckBox
                                x:Uid="TorrentCheckGeneralPage_CreateSubfolderCheckBox"
                                Grid.Row="2"
                                Grid.Column="1"
                                Grid.ColumnSpan="3" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border
                    Padding="12"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    CornerRadius="4">
                    <StackPanel Spacing="8">
                        <TextBlock x:Uid="TorrentCheckGeneralPage_TorrentContentTitle" FontWeight="SemiBold" />
                        <Grid
                            ColumnDefinitions="Auto,*"
                            ColumnSpacing="8"
                            RowDefinitions="Auto,Auto,Auto,Auto"
                            RowSpacing="4">
                            <TextBlock x:Uid="TorrentCheckGeneralPage_TorrentNameLabel" />
                            <TextBlock
                                Grid.Column="1"
                                Text="2024-2025-1计算机网络A卷.pdf"
                                TextTrimming="CharacterEllipsis" />

                            <TextBlock x:Uid="TorrentCheckGeneralPage_TorrentSizeLabel" Grid.Row="1" />
                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="1"
                                Text="337.3 KB" />

                            <TextBlock x:Uid="TorrentCheckGeneralPage_TorrentPublisherLabel" Grid.Row="2" />
                            <TextBlock
                                Grid.Row="2"
                                Grid.Column="1"
                                Text="" />
                        </Grid>

                        <Border
                            Padding="12"
                            Background="#FFE7CEF5"
                            CornerRadius="2">
                            <Grid ColumnDefinitions="*,*">
                                <TextBlock
                                    x:Uid="TorrentCheckGeneralPage_DiskSpace"
                                    HorizontalAlignment="Center"
                                    Foreground="Crimson" />
                                <TextBlock
                                    x:Uid="TorrentCheckGeneralPage_FreeSpace"
                                    Grid.Column="1"
                                    HorizontalAlignment="Center"
                                    Foreground="Crimson" />
                            </Grid>
                        </Border>

                        <Border
                            Padding="0"
                            BorderBrush="Gray"
                            BorderThickness="1"
                            CornerRadius="2">
                            <Grid RowDefinitions="Auto,*">
                                <Grid
                                    Padding="8"
                                    Background="#FF2F2F2F"
                                    ColumnDefinitions="*,140,80"
                                    ColumnSpacing="8">
                                    <TextBlock x:Uid="TorrentCheckGeneralPage_ListHeader_FileName" FontWeight="SemiBold" />
                                    <TextBlock
                                        x:Uid="TorrentCheckGeneralPage_ListHeader_Size"
                                        Grid.Column="1"
                                        HorizontalAlignment="Right"
                                        FontWeight="SemiBold" />
                                    <TextBlock
                                        x:Uid="TorrentCheckGeneralPage_ListHeader_Percent"
                                        Grid.Column="2"
                                        HorizontalAlignment="Right"
                                        FontWeight="SemiBold" />
                                </Grid>
                                <ScrollViewer
                                    Grid.Row="1"
                                    MinHeight="180"
                                    VerticalScrollBarVisibility="Auto">
                                    <StackPanel>
                                        <Grid
                                            Padding="8"
                                            VerticalAlignment="Center"
                                            ColumnDefinitions="Auto,*,140,80"
                                            ColumnSpacing="8">
                                            <CheckBox IsChecked="True" />
                                            <TextBlock
                                                Grid.Column="1"
                                                Text="2024-2025-1计算机网络A卷.pdf"
                                                TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                Grid.Column="2"
                                                HorizontalAlignment="Right"
                                                Text="337.3 KB" />
                                            <TextBlock
                                                Grid.Column="3"
                                                HorizontalAlignment="Right"
                                                Text="0.0%" />
                                        </Grid>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!--  Sticky bottom bar (always visible)  -->
        <Grid
            Grid.Row="1"
            VerticalAlignment="Bottom"
            ColumnDefinitions="*,Auto"
            ColumnSpacing="12">
            <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                <CheckBox
                    x:Uid="TorrentCheckGeneralPage_Filter_SelectAll"
                    MinHeight="12"
                    IsChecked="True" />
                <CheckBox x:Uid="TorrentCheckGeneralPage_Filter_Video" />
                <CheckBox x:Uid="TorrentCheckGeneralPage_Filter_Audio" />
                <CheckBox x:Uid="TorrentCheckGeneralPage_Filter_Picture" />
                <CheckBox x:Uid="TorrentCheckGeneralPage_Filter_Other" IsChecked="True" />
            </StackPanel>

            <StackPanel
                Grid.Column="1"
                HorizontalAlignment="Right"
                Orientation="Horizontal"
                Spacing="8">
                <Button x:Uid="TorrentCheckGeneralPage_Action_DownloadNow" />
                <Button x:Uid="TorrentCheckGeneralPage_Action_DownloadLater" />
                <Button x:Uid="TorrentCheckGeneralPage_Action_Cancel" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>
