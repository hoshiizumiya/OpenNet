<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="OpenNet.UI.Xaml.View.Pages.TorrentCheckGeneralPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:XamlToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:labs="using:XamlToolkit.Labs.WinUI"
    xmlns:local="using:OpenNet.UI.Xaml.View.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:vm="using:OpenNet.ViewModels"
    mc:Ignorable="d">

    <Grid
        Padding="16,0,16,16"
        VerticalAlignment="Stretch"
        RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Scrollable content  -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12">
                <!--  Save Location Section  -->
                <Border
                    Padding="12"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                    <StackPanel Spacing="8">
                        <TextBlock
                            x:Uid="AddMagnet_SaveLabel"
                            FontWeight="SemiBold"
                            Text="Save Location" />
                        <Grid
                            ColumnDefinitions="Auto,*,Auto"
                            ColumnSpacing="8"
                            RowDefinitions="Auto,Auto,Auto"
                            RowSpacing="8">
                            <TextBlock
                                x:Uid="TorrentCheckGeneralPage_SavePathLabel"
                                Margin="0,0,4,0"
                                VerticalAlignment="Center"
                                Text="Save to:" />

                            <AutoSuggestBox
                                x:Name="TorrentCheckGeneralPageSavePath"
                                x:Uid="TorrentCheckGeneralPageSavePath"
                                Grid.Column="1"
                                TextChanged="TorrentCheckGeneralPageSavePath_TextChanged"
                                PlaceholderText="Choose download location">
                                <AutoSuggestBox.QueryIcon>
                                    <FontIcon HorizontalAlignment="Center" Glyph="&#xE70D;" />
                                </AutoSuggestBox.QueryIcon>
                            </AutoSuggestBox>

                            <Button
                                x:Uid="TorrentCheckGeneralPage_FolderPickerButton"
                                Grid.Column="2"
                                MinWidth="36"
                                Click="TorrentCheckGeneralPageFolderPicker_Click"
                                ToolTipService.ToolTip="Browse...">
                                <Button.Content>
                                    <FontIcon Glyph="&#xEC50;" />
                                </Button.Content>
                            </Button>

                            <TextBlock
                                x:Uid="TorrentCheckGeneralPage_FileNameLabel"
                                Grid.Row="1"
                                Margin="0,0,4,0"
                                VerticalAlignment="Center"
                                Text="Save as:" />
                            <TextBox
                                x:Name="TorrentFileNameTextBox"
                                x:Uid="TorrentCheckGeneralPage_FileNameTextBox"
                                Grid.Row="1"
                                Grid.Column="1"
                                Grid.ColumnSpan="2" />

                            <CheckBox
                                x:Name="CreateSubfolderCheckBox"
                                x:Uid="TorrentCheckGeneralPage_CreateSubfolderCheckBox"
                                Grid.Row="2"
                                Grid.Column="1"
                                Grid.ColumnSpan="2"
                                Content="Create subfolder"
                                IsChecked="True" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!--  Torrent Content Section  -->
                <Border
                    Padding="12"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                    <StackPanel Spacing="8">
                        <TextBlock
                            x:Uid="TorrentCheckGeneralPage_TorrentContentTitle"
                            FontWeight="SemiBold"
                            Text="Torrent Content" />

                        <!--  Torrent Info Summary  -->
                        <Grid
                            ColumnDefinitions="Auto,*"
                            ColumnSpacing="8"
                            RowDefinitions="Auto,Auto,Auto"
                            RowSpacing="4">
                            <TextBlock x:Uid="TorrentCheckGeneralPage_TorrentNameLabel" Text="Name:" />
                            <TextBlock
                                x:Name="TorrentNameText"
                                Grid.Column="1"
                                Text=""
                                TextTrimming="CharacterEllipsis" />

                            <TextBlock
                                x:Uid="TorrentCheckGeneralPage_TorrentSizeLabel"
                                Grid.Row="1"
                                Text="Total Size:" />
                            <TextBlock
                                x:Name="TorrentSizeText"
                                Grid.Row="1"
                                Grid.Column="1"
                                Text="" />

                            <TextBlock
                                x:Uid="TorrentCheckGeneralPage_SelectedSizeLabel"
                                Grid.Row="2"
                                Text="Selected:" />
                            <TextBlock
                                x:Name="SelectedSizeText"
                                Grid.Row="2"
                                Grid.Column="1"
                                Text="" />
                        </Grid>

                        <!--  Disk Space Info  -->
                        <Border
                            Padding="12"
                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="4">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                <!--  HardDrive Icon  -->
                                <FontIcon
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    FontSize="20"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Glyph="&#xEDA2;" />
                                <!--  Progress Bar showing disk usage - fixed width container  -->
                                <Grid Grid.Column="1" MinWidth="200">
                                    <ProgressBar
                                        x:Name="DiskSpaceProgressBar"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Stretch"
                                        IsIndeterminate="False"
                                        Maximum="100"
                                        ShowError="False"
                                        ShowPaused="False"
                                        Value="0" />
                                </Grid>
                                <!--  Space info (fixed width to prevent layout shift)  -->
                                <StackPanel
                                    Grid.Column="2"
                                    MinWidth="320"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal"
                                    Spacing="16">
                                    <!--  Required space  -->
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock
                                            x:Uid="TorrentCheckGeneralPage_DiskSpaceRequired"
                                            VerticalAlignment="Center"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="Required:" />
                                        <TextBlock
                                            x:Name="DiskSpaceText"
                                            MinWidth="80"
                                            VerticalAlignment="Center"
                                            FontWeight="SemiBold"
                                            Text="--" />
                                    </StackPanel>
                                    <!--  Free space  -->
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock
                                            x:Uid="TorrentCheckGeneralPage_DiskSpaceFree"
                                            VerticalAlignment="Center"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="Free:" />
                                        <TextBlock
                                            x:Name="FreeSpaceText"
                                            MinWidth="80"
                                            VerticalAlignment="Center"
                                            FontWeight="SemiBold"
                                            Text="--" />
                                    </StackPanel>
                                    <!--  Total space  -->
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock
                                            x:Uid="TorrentCheckGeneralPage_DiskSpaceTotal"
                                            VerticalAlignment="Center"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="Total:" />
                                        <TextBlock
                                            x:Name="TotalSpaceText"
                                            MinWidth="80"
                                            VerticalAlignment="Center"
                                            FontWeight="SemiBold"
                                            Text="--" />
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!--  File List using HeaderedTreeView with DataTable  -->
                        <Border
                            Padding="0"
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="2">
                            <controls:HeaderedTreeView
                                x:Name="TorrentFileTreeView"
                                MaxHeight="300"
                                ItemsSource="{x:Bind ViewModel.FileTree}"
                                SelectionMode="None">
                                <controls:HeaderedTreeView.Header>
                                    <Border Padding="8" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                        <labs:DataTable ColumnSpacing="8">
                                            <!--  Select checkbox column - Fixed width  -->
                                            <labs:DataColumn DesiredWidth="32" MinWidth="32">
                                                <CheckBox
                                                    x:Name="SelectAllHeaderCheckBox"
                                                    Checked="SelectAllCheckBox_Checked"
                                                    IsChecked="True"
                                                    Unchecked="SelectAllCheckBox_Unchecked" />
                                            </labs:DataColumn>
                                            <!--  File Name column - Star width (fills remaining space)  -->
                                            <labs:DataColumn DesiredWidth="*">
                                                <TextBlock
                                                    x:Uid="TorrentCheckGeneralPage_ListHeader_FileName"
                                                    FontWeight="SemiBold"
                                                    Text="File Name" />
                                            </labs:DataColumn>
                                            <!--  Size column - Fixed width  -->
                                            <labs:DataColumn DesiredWidth="100" HorizontalContentAlignment="Right">
                                                <TextBlock
                                                    x:Uid="TorrentCheckGeneralPage_ListHeader_Size"
                                                    FontWeight="SemiBold"
                                                    Text="Size" />
                                            </labs:DataColumn>
                                            <!--  Priority column - Fixed width  -->
                                            <labs:DataColumn DesiredWidth="80" HorizontalContentAlignment="Right">
                                                <TextBlock
                                                    x:Uid="TorrentCheckGeneralPage_ListHeader_Priority"
                                                    FontWeight="SemiBold"
                                                    Text="Priority" />
                                            </labs:DataColumn>
                                        </labs:DataTable>
                                    </Border>
                                </controls:HeaderedTreeView.Header>
                                <controls:HeaderedTreeView.ItemTemplate>
                                        <DataTemplate x:DataType="vm:TorrentFileNodeViewModel">
                                            <muxc:TreeViewItem
                                                IsExpanded="{x:Bind IsExpanded, Mode=TwoWay}"
                                                ItemsSource="{x:Bind Children}">
                                                <Grid ColumnDefinitions="32,*,100,80" ColumnSpacing="8">
                                                    <!--  Checkbox for selection  -->
                                                    <CheckBox
                                                        Click="FileCheckBox_Click"
                                                        IsChecked="{x:Bind IsSelected, Mode=TwoWay}" />
                                                    <!--  File name with icon  -->
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                                        <FontIcon
                                                            VerticalAlignment="Center"
                                                            FontSize="16"
                                                            Glyph="{x:Bind local:TorrentCheckGeneralPage.GetNodeIcon(IsFolder)}" />
                                                        <TextBlock
                                                            VerticalAlignment="Center"
                                                            Text="{x:Bind Name}"
                                                            TextTrimming="CharacterEllipsis"
                                                            ToolTipService.ToolTip="{x:Bind FullPath}" />
                                                    </StackPanel>
                                                    <!--  Size  -->
                                                    <TextBlock
                                                        Grid.Column="2"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center"
                                                        Text="{x:Bind SizeText}" />
                                                    <!--  Priority  -->
                                                    <TextBlock
                                                        Grid.Column="3"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center"
                                                        Text="{x:Bind PriorityText}" />
                                                </Grid>
                                            </muxc:TreeViewItem>
                                        </DataTemplate>
                                    </controls:HeaderedTreeView.ItemTemplate>
                            </controls:HeaderedTreeView>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!--  Bottom Filter Bar  -->
        <Grid
            Grid.Row="1"
            VerticalAlignment="Bottom"
            ColumnDefinitions="*"
            ColumnSpacing="12">
            <StackPanel
                HorizontalAlignment="Left"
                Orientation="Horizontal"
                Spacing="4">
                <CheckBox
                    x:Name="SelectAllFilterCheckBox"
                    x:Uid="TorrentCheckGeneralPage_Filter_SelectAll"
                    MinHeight="12"
                    Checked="SelectAllCheckBox_Checked"
                    Content="Select All"
                    IsChecked="True"
                    Unchecked="SelectAllCheckBox_Unchecked" />
                <CheckBox
                    x:Name="VideoFilterCheckBox"
                    x:Uid="TorrentCheckGeneralPage_Filter_Video"
                    Checked="FilterCheckBox_Checked"
                    Content="Video"
                    Tag=".mp4,.mkv,.avi,.mov,.wmv"
                    Unchecked="FilterCheckBox_Unchecked" />
                <CheckBox
                    x:Name="AudioFilterCheckBox"
                    x:Uid="TorrentCheckGeneralPage_Filter_Audio"
                    Checked="FilterCheckBox_Checked"
                    Content="Audio"
                    Tag=".mp3,.flac,.wav,.aac,.ogg"
                    Unchecked="FilterCheckBox_Unchecked" />
                <CheckBox
                    x:Name="PictureFilterCheckBox"
                    x:Uid="TorrentCheckGeneralPage_Filter_Picture"
                    Checked="FilterCheckBox_Checked"
                    Content="Picture"
                    Tag=".jpg,.jpeg,.png,.gif,.bmp,.webp"
                    Unchecked="FilterCheckBox_Unchecked" />
                <CheckBox
                    x:Name="OtherFilterCheckBox"
                    x:Uid="TorrentCheckGeneralPage_Filter_Other"
                    Checked="FilterCheckBox_Checked"
                    Content="Other"
                    IsChecked="True"
                    Tag="other"
                    Unchecked="FilterCheckBox_Unchecked" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>
