<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="OpenNet.UI.Xaml.View.Pages.MainView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:animatedvisuals="using:Microsoft.UI.Xaml.Controls.AnimatedVisuals"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:essential="using:WinUI3Package"
    xmlns:local="using:OpenNet.UI.Xaml.View.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:xtwa="using:XamlToolkit.WinUI.Animations"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  导航面板 / Navigation Panel  -->
        <NavigationView
            x:Name="NavView"
            x:Uid="NavView"
            Grid.Row="0"
            HighContrastAdjustment="None"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleButtonVisible="False"
            IsSettingsVisible="False"
            ItemInvoked="NavView_ItemInvoked"
            SelectionChanged="NavView_SelectionChanged"
            Style="{StaticResource MainNavigationViewStyle}">
            <NavigationView.MenuItems>
                <!--  主页 / Home  -->
                <NavigationViewItem
                    x:Name="NavItem_Home"
                    x:Uid="NavItem_Home"
                    Tag="home">
                    <NavigationViewItem.Icon>
                        <FontIcon
                            x:Name="HomeIcon"
                            xtwa:Implicit.Animations="{StaticResource IconOpacityAnim}"
                            Glyph="&#xE80F;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem
                    x:Name="NavItem_Tasks"
                    x:Uid="NavItem_Tasks"
                    Content="Tasks"
                    Tag="tasks">
                    <NavigationViewItem.Icon>
                        <FontIcon
                            x:Name="TasksIcon"
                            xtwa:Implicit.Animations="{StaticResource IconOpacityAnim}"
                            Glyph="&#xE7C4;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem
                    x:Uid="NavItem_RSS"
                    Content="RSS"
                    Tag="rss">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8F1;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem
                    x:Uid="NavItem_NatTools"
                    Content="NAT Tools"
                    Tag="nattools">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE968;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <!--  底部  -->
            <NavigationView.FooterMenuItems>
                <!--<NavigationViewItem
                    Content="Contribute"
                    SelectsOnInvoked="False"
                    Tag="Contribute">
                    <NavigationViewItem.Icon>
                        <ImageIcon Opacity="0.6" Source="{ThemeResource GitHubIconImage}" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>-->
                <NavigationViewItem
                    x:Name="NavItem_Settings"
                    x:Uid="NavItem_Settings"
                    Tag="settings">
                    <!--<NavigationViewItem.Content>
                    -->
                    <!--<FontIcon
                            x:Name="SettingsIcon"
                            Glyph="&#xE713;" />-->
                    <NavigationViewItem.Icon>
                        <AnimatedIcon
                            x:Name="AnimatedIcon"
                            PointerEntered="SettingButton_PointerEntered"
                            PointerExited="SettingButton_PointerExited">
                            <AnimatedIcon.Source>
                                <animatedvisuals:AnimatedSettingsVisualSource />
                            </AnimatedIcon.Source>
                            <AnimatedIcon.FallbackIconSource>
                                <FontIconSource Glyph="&#xE713;" />
                            </AnimatedIcon.FallbackIconSource>
                        </AnimatedIcon>
                    </NavigationViewItem.Icon>

                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <NavigationView.Content>
                <Frame
                    x:Name="NavFrame"
                    Navigated="NavFrame_Navigated"
                    Navigating="NavFrame_Navigating" />
            </NavigationView.Content>
        </NavigationView>

        <!--  状态栏 / Status Bar  -->
        <Grid
            x:Uid="StatusBar"
            Grid.Row="1"
            Padding="12,6"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!--  Speed Display  -->
            <StackPanel
                Grid.Column="0"
                Margin="0,0,16,0"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="8">
                <essential:SwitchPresenter Padding="8" Value="{x:Bind ViewModel.SpeedLevel, Mode=OneWay}">
                    <essential:Case Value="Low">
                        <FontIcon FontSize="14" Glyph="&#xEC48;" />
                    </essential:Case>
                    <essential:Case Value="Medium">
                        <FontIcon FontSize="14" Glyph="&#xEC49;" />
                    </essential:Case>
                    <essential:Case Value="High">
                        <FontIcon FontSize="14" Glyph="&#xEC4A;" />
                    </essential:Case>
                </essential:SwitchPresenter>
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="12"
                    Text="{x:Bind ViewModel.CurrentTransferSpeedText, Mode=OneWay, FallbackValue='↓ 0 B/s  ↑ 0 B/s'}" />
            </StackPanel>

            <!--  Connection Status  -->
            <Border
                Grid.Column="1"
                Margin="0,0,16,0"
                Padding="8,4"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                CornerRadius="4">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon
                        FontSize="12"
                        Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                        Glyph="&#xF22C;" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="12"
                        Text="{x:Bind ViewModel.ConnectedPeersCount, Mode=OneWay, FallbackValue='0'}" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="Peers" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                        Text="|" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="12"
                        Text="{x:Bind ViewModel.DhtNodeCount, Mode=OneWay, FallbackValue='0'}" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="DHT" />
                </StackPanel>
            </Border>

            <!--  Error / Notification Area  -->
            <StackPanel
                Grid.Column="2"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="12">
                <!--  Error Information  -->
                <StackPanel
                    Orientation="Horizontal"
                    Spacing="6"
                    Visibility="{x:Bind ViewModel.HasError, Mode=OneWay}">
                    <FontIcon
                        FontSize="12"
                        Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                        Glyph="&#xEA39;" />
                    <TextBlock
                        FontSize="12"
                        Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                        Text="{x:Bind ViewModel.LastError, Mode=OneWay}"
                        TextTrimming="CharacterEllipsis" />
                    <Button
                        Width="20"
                        Height="20"
                        Padding="0"
                        Command="{x:Bind ViewModel.ClearErrorCommand}"
                        Style="{StaticResource SubtleButtonStyle}">
                        <FontIcon FontSize="10" Glyph="&#xE711;" />
                    </Button>
                </StackPanel>

                <!--  User Info  -->
                <StackPanel
                    Grid.Column="4"
                    Margin="16,0,0,0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="6">
                    <FontIcon
                        FontSize="12"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Glyph="&#xE77B;" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Text="{x:Bind ViewModel.UserName, Mode=OneWay}" />
                </StackPanel>
            </StackPanel>

            <!--  Port State  -->
            <StackPanel
                Grid.Column="3"
                Margin="16,0,0,0"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="6">
                <essential:SwitchPresenter Padding="0" Value="{x:Bind ViewModel.PortState, Mode=OneWay}">
                    <essential:Case Value="Unknown">
                        <FontIcon
                            FontFamily="Segoe UI Emoji"
                            FontSize="14"
                            Glyph="&#x1F7E4;" />
                    </essential:Case>
                    <essential:Case Value="Open">
                        <FontIcon
                            FontFamily="Segoe UI Emoji"
                            FontSize="14"
                            Glyph="&#x1F7E2;" />
                    </essential:Case>
                    <essential:Case Value="Blocked">
                        <FontIcon
                            FontFamily="Segoe UI Emoji"
                            FontSize="20"
                            Glyph="&#x1F7E1;">
                            <ToolTipService.ToolTip>
                                <ToolTip essential:ToolTipHelper.AcrylicWorkaround="True" Content="Port is blocked. Please check your router or firewall settings." />
                            </ToolTipService.ToolTip>
                        </FontIcon>
                    </essential:Case>
                </essential:SwitchPresenter>
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="12"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{x:Bind ViewModel.ListenPort, Mode=OneWay, FallbackValue='0'}" />
            </StackPanel>

            <!--  Notification Information  -->
            <StackPanel
                Orientation="Horizontal"
                Spacing="6"
                Visibility="{x:Bind ViewModel.HasNotification, Mode=OneWay}">
                <FontIcon
                    FontSize="12"
                    Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                    Glyph="&#xE946;" />
                <TextBlock
                    FontSize="12"
                    Text="{x:Bind ViewModel.LastNotification, Mode=OneWay}"
                    TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>
