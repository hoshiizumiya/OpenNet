<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="OpenNet.UI.Xaml.View.Pages.TaskPeersListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:labs="using:XamlToolkit.Labs.WinUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Peer list  -->
        <ListView
            x:Name="PeersListView"
            Grid.Row="1"
            SelectionMode="None">
            <!--  Column Headers  -->
            <ListView.Header>
                <Border
                    Padding="8,4,0,4"
                    Background="{ThemeResource SolidBackgroundFillColorTertiaryBrush}"
                    CornerRadius="4">
                    <labs:DataTable ColumnSpacing="16">
                        <labs:DataColumn>
                            <TextBlock
                                x:Uid="PeerHeader_IP"
                                FontWeight="SemiBold"
                                Text="IP" />
                        </labs:DataColumn>
                        <labs:DataColumn>
                            <TextBlock
                                x:Uid="PeerHeader_Client"
                                FontWeight="SemiBold"
                                Text="Client" />

                        </labs:DataColumn>
                        <labs:DataColumn>
                            <TextBlock
                                x:Uid="PeerHeader_Progress"
                                FontWeight="SemiBold"
                                Text="Progress" />

                        </labs:DataColumn>
                        <labs:DataColumn>
                            <TextBlock
                                x:Uid="PeerHeader_DLSpeed"
                                FontWeight="SemiBold"
                                Text="DL Speed" />

                        </labs:DataColumn>
                        <labs:DataColumn>
                            <TextBlock
                                x:Uid="PeerHeader_ULSpeed"
                                FontWeight="SemiBold"
                                Text="UL Speed" />

                        </labs:DataColumn>
                        <labs:DataColumn>
                            <TextBlock
                                x:Uid="PeerHeader_Downloaded"
                                FontWeight="SemiBold"
                                Text="Downloaded" />

                        </labs:DataColumn>
                    </labs:DataTable>

                </Border>
            </ListView.Header>
            <ListView.ItemTemplate>
                <!--  任务：换成x:Bind，绑定到PeerInfo对象的属性，而不是使用索引器绑定到字典  -->
                <DataTemplate>
                    <labs:DataRow HorizontalAlignment="Left">
                        <TextBlock Text="{Binding [IP]}" />
                        <TextBlock Text="{Binding [Client]}" />
                        <TextBlock Text="{Binding [Progress]}" />
                        <TextBlock Text="{Binding [DLSpeed]}" />
                        <TextBlock Text="{Binding [ULSpeed]}" />
                        <TextBlock Text="{Binding [Downloaded]}" />
                    </labs:DataRow>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!--  Empty state when no task selected or no peers  -->
        <TextBlock
            x:Name="EmptyStateText"
            x:Uid="PeersList_EmptyState"
            Grid.Row="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            Text="No peers connected"
            Visibility="Collapsed" />
    </Grid>
</Page>
