<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="OpenNet.UI.Xaml.View.Pages.TaskPeersListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Column Headers -->
        <Grid Grid.Row="0"
              Padding="8,4"
              Background="{ThemeResource SystemControlAcrylicWindowBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Uid="PeerHeader_IP"
                       Grid.Column="0"
                       FontWeight="SemiBold"
                       Text="IP"/>
            <TextBlock x:Uid="PeerHeader_Client"
                       Grid.Column="1"
                       FontWeight="SemiBold"
                       Text="Client"/>
            <TextBlock x:Uid="PeerHeader_Progress"
                       Grid.Column="2"
                       FontWeight="SemiBold"
                       Text="Progress"/>
            <TextBlock x:Uid="PeerHeader_DLSpeed"
                       Grid.Column="3"
                       FontWeight="SemiBold"
                       Text="DL Speed"/>
            <TextBlock x:Uid="PeerHeader_ULSpeed"
                       Grid.Column="4"
                       FontWeight="SemiBold"
                       Text="UL Speed"/>
            <TextBlock x:Uid="PeerHeader_Downloaded"
                       Grid.Column="5"
                       FontWeight="SemiBold"
                       Text="Downloaded"/>
        </Grid>

        <!-- Peer list -->
        <ListView x:Name="PeersListView"
                  Grid.Row="1"
                  SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="8,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                Text="{Binding [IP]}"/>
                        <TextBlock Grid.Column="1"
                                Text="{Binding [Client]}"/>
                        <TextBlock Grid.Column="2"
                                Text="{Binding [Progress]}"/>
                        <TextBlock Grid.Column="3"
                                Text="{Binding [DLSpeed]}"/>
                        <TextBlock Grid.Column="4"
                                Text="{Binding [ULSpeed]}"/>
                        <TextBlock Grid.Column="5"
                                Text="{Binding [Downloaded]}"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Empty state when no task selected or no peers -->
        <TextBlock x:Name="EmptyStateText"
                   x:Uid="PeersList_EmptyState"
                   Grid.Row="1"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   Text="No peers connected"
                   Visibility="Collapsed"/>
    </Grid>
</Page>
