<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="OpenNet.UI.Xaml.View.Pages.TaskPeersListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:essential="using:WinUI3Package"
    xmlns:labs="using:XamlToolkit.Labs.WinUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:OpenNet.ViewModels"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Peer list  -->
        <ListView
            x:Name="PeersListView"
            Grid.Row="1"
            SelectionMode="Single">
            <ListView.ContextFlyout>
                <MenuFlyout>
                    <MenuFlyoutItem
                        x:Name="BanPeer1hItem"
                        x:Uid="BanPeer1hItem"
                        Click="BanPeer1h_Click"
                        Text="Ban IP for 1 hour" />
                    <MenuFlyoutItem
                        x:Name="BanPeer24hItem"
                        x:Uid="BanPeer24hItem"
                        Click="BanPeer24h_Click"
                        Text="Ban IP for 24 hours" />
                    <MenuFlyoutItem
                        x:Name="BanPeerPermanentItem"
                        x:Uid="BanPeerPermanentItem"
                        Click="BanPeerPermanent_Click"
                        Text="Ban IP permanently" />
                </MenuFlyout>
            </ListView.ContextFlyout>
            <!--  Column Headers  -->
            <ListView.Header>
                <Border
                    Padding="8,4,0,4"
                    Background="{ThemeResource SolidBackgroundFillColorTertiaryBrush}"
                    CornerRadius="4">
                    <labs:DataTable ColumnSpacing="16">
                        <labs:DataColumn DesiredWidth="2*">
                            <TextBlock
                                x:Uid="PeerHeader_IP"
                                FontWeight="SemiBold"
                                Text="IP" />
                        </labs:DataColumn>
                        <labs:DataColumn DesiredWidth="*">
                            <TextBlock
                                x:Uid="PeerHeader_Location"
                                FontWeight="SemiBold"
                                Text="Location" />
                        </labs:DataColumn>
                        <labs:DataColumn DesiredWidth="*">
                            <TextBlock
                                x:Uid="PeerHeader_Progress"
                                FontWeight="SemiBold"
                                Text="Progress" />
                        </labs:DataColumn>
                        <labs:DataColumn DesiredWidth="*">
                            <TextBlock
                                x:Uid="PeerHeader_DLSpeed"
                                FontWeight="SemiBold"
                                Text="DL Speed" />
                        </labs:DataColumn>
                        <labs:DataColumn DesiredWidth="*">
                            <TextBlock
                                x:Uid="PeerHeader_ULSpeed"
                                FontWeight="SemiBold"
                                Text="UL Speed" />
                        </labs:DataColumn>
                        <labs:DataColumn DesiredWidth="*">
                            <TextBlock
                                x:Uid="PeerHeader_Downloaded"
                                FontWeight="SemiBold"
                                Text="Downloaded" />
                        </labs:DataColumn>
                        <labs:DataColumn DesiredWidth="*">
                            <TextBlock
                                x:Uid="PeerHeader_Client"
                                FontWeight="SemiBold"
                                Text="Client" />
                        </labs:DataColumn>
                        <labs:DataColumn DesiredWidth="*">
                            <TextBlock
                                x:Uid="PeerHeader_PeerStatus"
                                FontWeight="SemiBold"
                                Text="Status" />
                        </labs:DataColumn>
                        <labs:DataColumn DesiredWidth="*">
                            <TextBlock
                                x:Uid="PeerHeader_Protocol"
                                FontWeight="SemiBold"
                                Text="Protocol" />
                        </labs:DataColumn>
                        <labs:DataColumn DesiredWidth="*">
                            <TextBlock
                                x:Uid="PeerHeader_Initiator"
                                FontWeight="SemiBold"
                                Text="Initiator" />
                        </labs:DataColumn>
                        <labs:DataColumn DesiredWidth="*">
                            <TextBlock
                                x:Uid="PeerHeader_Source"
                                FontWeight="SemiBold"
                                Text="Source" />
                        </labs:DataColumn>
                    </labs:DataTable>

                </Border>
            </ListView.Header>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:PeerDisplayItem">
                    <labs:DataRow HorizontalAlignment="Left">
                        <TextBlock Text="{x:Bind IP}" />
                        <TextBlock Text="{x:Bind Location}" />
                        <TextBlock Text="{x:Bind Progress}" />
                        <TextBlock Text="{x:Bind DLSpeed}" />
                        <TextBlock Text="{x:Bind ULSpeed}" />
                        <TextBlock Text="{x:Bind Downloaded}" />
                        <TextBlock Text="{x:Bind Client}" />
                        <TextBlock Text="{x:Bind PeerStatus}" />
                        <TextBlock Text="{x:Bind Protocol}" />
                        <TextBlock Text="{x:Bind Initiator}" />
                        <TextBlock Text="{x:Bind Source}" />
                    </labs:DataRow>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!--  Empty state when no task selected or no peers  -->
        <TextBlock
            x:Name="EmptyStateText"
            x:Uid="PeersList_EmptyState"
            Grid.Row="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            Text="No peers connected"
            Visibility="Collapsed" />
    </Grid>
</Page>
