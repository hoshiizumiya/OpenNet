<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="OpenNet.UI.Xaml.View.Dialog.CloseToTrayDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:OpenNet.UI.Xaml.View.Dialog"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Uid="ViewDialogCloseToTrayDialog"
    Title="window close action"
    CloseButtonText="Exit application"
    PrimaryButtonText="Close to tray"
    Style="{StaticResource DefaultContentDialogStyle}"
    mc:Ignorable="d">

    <StackPanel Padding="12" Spacing="12">
        <TextBlock
            x:Uid="ViewDialogCloseToTrayQuestion"
            Text="When closing the main window, please choose an action:"
            TextWrapping="Wrap" />
        <CheckBox
            x:Name="ChkRemember"
            x:Uid="ViewDialogCloseToTrayRememberCheckBox"
            Content="Remember my choice, do not ask again" />
    </StackPanel>
</ContentDialog>
