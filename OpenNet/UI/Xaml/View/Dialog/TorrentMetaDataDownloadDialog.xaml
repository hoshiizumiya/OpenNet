<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="OpenNet.UI.Xaml.View.Dialog.TorrentMetaDataDownloadDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:OpenNet.UI.Xaml.View.Dialog"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="UIXamlViewDialogTorrentMetaDataDownloadDialog"
    x:Uid="UIXamlViewDialogTorrentMetaDataDownloadDialog"
    Title="添加磁力链接 / Add Magnet"
    CloseButtonText="取消"
    DefaultButton="Primary"
    PrimaryButtonText="确定"
    Style="{StaticResource DefaultContentDialogStyle}"
    mc:Ignorable="d">

    <StackPanel Padding="16" Spacing="8">
        <TextBlock Text="磁力链接 / Magnet Link:" />
        <TextBox
            x:Name="MagnetBox"
            MinWidth="480"
            PlaceholderText="magnet:?xt=..." />

    </StackPanel>
</ContentDialog>
