<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="OpenNet.UI.Xaml.Control.HomePage.Header.HeaderCarousel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:OpenNet.UI.Xaml.Control.HomePage.Header"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Loaded="UserControl_Loaded"
    Unloaded="UserControl_Unloaded"
    mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <RadialGradientBrush x:Key="OverlayRadialGradient"
                                         Center="0.5,0.22"
                                         GradientOrigin="0.5,0"
                                         MappingMode="RelativeToBoundingBox"
                                         RadiusX="0.92"
                                         RadiusY="0.82"
                                         SpreadMethod="Pad">
                        <GradientStop Offset="0"
                                Color="#00FFFFFF"/>
                        <GradientStop Offset="0.55"
                                Color="#00FFFFFF"/>
                        <GradientStop Offset="0.85"
                                Color="#FFFFFFFF"/>
                        <GradientStop Offset="1"
                                Color="#FFFFFFFF"/>
                    </RadialGradientBrush>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <RadialGradientBrush x:Key="OverlayRadialGradient"
                                         Center="0.5,0.22"
                                         GradientOrigin="0.5,0"
                                         MappingMode="RelativeToBoundingBox"
                                         RadiusX="0.92"
                                         RadiusY="0.82"
                                         SpreadMethod="Pad">
                        <GradientStop Offset="0"
                                Color="#00000000"/>
                        <GradientStop Offset="0.55"
                                Color="#00000000"/>
                        <GradientStop Offset="0.85"
                                Color="#FF000000"/>
                        <GradientStop Offset="1"
                                Color="#FF000000"/>
                    </RadialGradientBrush>
                </ResourceDictionary>
                <ResourceDictionary x:Key="HighContrast">
                    <RadialGradientBrush x:Key="OverlayRadialGradient"
                                         Center="0.5,0.22"
                                         GradientOrigin="0.5,0"
                                         MappingMode="RelativeToBoundingBox"
                                         RadiusX="0.92"
                                         RadiusY="0.82"
                                         SpreadMethod="Pad">
                        <GradientStop Offset="0"
                                Color="#00000000"/>
                        <GradientStop Offset="0.55"
                                Color="#00000000"/>
                        <GradientStop Offset="0.95"
                                Color="#FF000000"/>
                        <GradientStop Offset="1"
                                Color="#FF000000"/>
                    </RadialGradientBrush>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
            <LinearGradientBrush x:Key="LightTextGradient"
                    StartPoint="0,0"
                    EndPoint="1,1">
                <GradientStop Offset="0.1"
                        Color="#FFFFFF"/>
                <GradientStop Offset="0.3"
                        Color="#E9E9E9"/>
                <GradientStop Offset="0.6"
                        Color="#FDFDFD"/>
                <GradientStop Offset="0.9"
                        Color="#FFFFFF"/>
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="DarkTextGradient"
                    StartPoint="0,0"
                    EndPoint="1,1">
                <GradientStop Offset="0.1"
                        Color="#303030"/>
                <GradientStop Offset="0.3"
                        Color="#4A4A4A"/>
                <GradientStop Offset="0.6"
                        Color="#161515"/>
                <GradientStop Offset="0.9"
                        Color="#303030"/>
            </LinearGradientBrush>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid x:Name="RootGrid"
            CornerRadius="8,0,0,0">
        <!--  Blurred backdrop image  -->
        <Grid HorizontalAlignment="Stretch"
                VerticalAlignment="Top">
            <local:AnimatedImage x:Name="BackDropImage"
                                 Height="400"
                                 BlurAmount="100"
                                 Visibility="Visible"/>
            <!--  Vignette overlay: fades edges into page background  -->
            <Rectangle Fill="{ThemeResource OverlayRadialGradient}"
                    Height="400"/>
        </Grid>

        <!--  Scrollable tile panel  -->
        <ScrollViewer
            x:Name="scrollViewer"
            Margin="0,24,0,0"
            HorizontalScrollBarVisibility="Hidden"
            VerticalScrollBarVisibility="Disabled"
            VerticalScrollMode="Disabled">
            <StackPanel
                x:Name="TilePanel"
                Padding="64,0,64,0"
                Orientation="Horizontal"
                Spacing="-48">
                <local:HeaderTile
                    Description="Transfer files securely across your P2P network"
                    Foreground="{StaticResource DarkTextGradient}"
                    Header="File Transfer"
                    ImageUrl="ms-appx:///Assets/TileImages/FileTransfer.png"
                    FeatureID="file-transfer"/>
                <local:HeaderTile
                    Description="Discover and connect to peers on your local network"
                    Foreground="{StaticResource DarkTextGradient}"
                    Header="Network Discovery"
                    ImageUrl="ms-appx:///Assets/TileImages/NetworkDiscovery.png"
                    FeatureID="network-discovery"/>
                <local:HeaderTile
                    Description="Chat with peers in real-time over secure channels"
                    Foreground="{StaticResource DarkTextGradient}"
                    Header="Peer Chat"
                    ImageUrl="ms-appx:///Assets/TileImages/PeerChat.png"
                    FeatureID="peer-chat"/>
                <local:HeaderTile
                    Description="Create secure encrypted tunnels between devices"
                    Foreground="{StaticResource LightTextGradient}"
                    Header="VPN Tunnel"
                    ImageUrl="ms-appx:///Assets/TileImages/VPNTunnel.png"
                    FeatureID="vpn-tunnel"/>
                <local:HeaderTile
                    Description="Share folders and storage with your network peers"
                    Foreground="{StaticResource DarkTextGradient}"
                    Header="Shared Storage"
                    ImageUrl="ms-appx:///Assets/TileImages/SharedStorage.png"
                    FeatureID="shared-storage"/>
                <local:HeaderTile
                    Description="Monitor network bandwidth and performance in real-time"
                    Foreground="{StaticResource DarkTextGradient}"
                    Header="Bandwidth Monitor"
                    ImageUrl="ms-appx:///Assets/TileImages/BandwidthMonitor.png"
                    FeatureID="bandwidth-monitor"/>
            </StackPanel>
        </ScrollViewer>

        <!--  Title overlay  -->
        <StackPanel Padding="24,12,24,24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Orientation="Vertical"
                    Spacing="12">
            <TextBlock HorizontalAlignment="Center"
                       CharacterSpacing="48"
                       FontSize="40"
                       FontWeight="Bold"
                       Opacity="0.8"
                       Text="OpenNet"
                       TextAlignment="Center"
                       TextWrapping="Wrap">
                <TextBlock.Foreground>
                    <LinearGradientBrush x:Name="AnimatedGradientBrush"
                                         StartPoint="0,0"
                                         EndPoint="1,1">
                        <GradientStop Offset="0.1"
                                Color="#303030"/>
                        <GradientStop Offset="0.3"
                                Color="#4A4A4A"/>
                        <GradientStop Offset="0.6"
                                Color="#161515"/>
                        <GradientStop Offset="0.9"
                                Color="#303030"/>
                    </LinearGradientBrush>
                </TextBlock.Foreground>
            </TextBlock>
            <Grid RequestedTheme="Light">
                <Grid Background="{ThemeResource AcrylicBackgroundFillColorBaseBrush}"
                      CornerRadius="12"
                      Opacity="0.6"/>
                <TextBlock Margin="10,4,10,4"
                           HorizontalAlignment="Center"
                           FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextAlignment="Center"
                           TextWrapping="Wrap">
                    <Run Text="Peer-to-peer networking made simple."/>
                    <Run Text="Securely connect, share, and communicate."/>
                </TextBlock>
            </Grid>
        </StackPanel>
    </Grid>
</UserControl>
