<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="OpenNet.UI.Shell.NotifyIconContextMenu"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:essential="using:WinUI3Package"
    xmlns:local="using:OpenNet.UI.Shell"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <essential:TaskbarIcon
            x:Name="trayIcon"
            x:Uid="trayIcon"
            Guid="{x:Bind local:NotifyIconContextMenu.IconGuid}"
            Icon="ms-appx:///Assets/AppIcons/win3264.ico"
            LeftDoublePressed="ShowMainWindow"
            LeftPressed="ShowMainWindow"
            ToolTip="OpenNet">
            <MenuFlyout>
                <MenuFlyoutItem Click="{x:Bind ShowMainWindow}" Text="Show" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Click="{x:Bind ExitApplication}" Text="Exit" />
            </MenuFlyout>
        </essential:TaskbarIcon>
    </Page.Resources>
</Page>
