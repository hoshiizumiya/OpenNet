<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="OpenNet.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:essential="using:WinUI3Package"
    xmlns:local="using:OpenNet"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pages="using:OpenNet.UI.Xaml.View.Pages"
    x:Uid="MainWindowRoot"
    Title="OpenNet"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" Loaded="Grid_Loaded">
        <Grid.Resources>
            <essential:ModernStandardWindowContextMenu x:Name="Menu" Window="{x:Bind}" />
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  标题栏 / Title Bar  -->
        <TitleBar
            x:Name="AppTitleBar"
            x:Uid="AppTitleBar"
            Grid.Row="0"
            Height="48"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Top"
            BackRequested="AppTitleBar_BackRequested"
            IsTabStop="False">

            <TitleBar.LeftHeader>
                <Image
                    x:Name="titleBarIcon"
                    Width="16"
                    Margin="10,0,10,0"
                    AutomationProperties.AccessibilityView="Raw"
                    Source="ms-appx:///Assets/AppIcons/Square44x44Logo.altform-lightunplated_targetsize-256.png" />
            </TitleBar.LeftHeader>
        </TitleBar>

        <!--  Main content: NavigationView + StatusBar  -->
        <pages:MainView x:Name="MainContentView" Grid.Row="1" />
    </Grid>
</Window>
