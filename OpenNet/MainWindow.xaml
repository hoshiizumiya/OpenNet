<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="OpenNet.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:OpenNet"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="OpenNet"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt" />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  标题栏 / Title Bar  -->
        <!--  Background="{ThemeResource SystemAccentColor}"  -->
        <TitleBar
            x:Name="AppTitleBar"
            Title="{StaticResource AppTitleName}"
            Grid.Row="0"
            Height="48"
            IsBackButtonVisible="True">

            <TitleBar.LeftHeader>
                <Image
                    x:Name="HeadLogo"
                    Width="16"
                    Margin="10,0,10,0"
                    AutomationProperties.AccessibilityView="Raw"
                    Source="ms-appx:///Assets/AppIcons/Square44x44Logo.altform-lightunplated_targetsize-256.png" />
            </TitleBar.LeftHeader>

            <TitleBar.Content>
                <AutoSuggestBox
                    x:Name="SearchBox"
                    MinWidth="364"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    PlaceholderText="Search anything"
                    QueryIcon="Find"
                    UpdateTextOnSelect="False" />
            </TitleBar.Content>

            <TitleBar.RightHeader>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock
                        VerticalAlignment="Center"
                        Foreground="White"
                        Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" />
                    <Button
                        Width="40"
                        Height="40"
                        Command="{x:Bind ViewModel.ShowAboutCommand}"
                        Content="ℹ️"
                        Style="{StaticResource AccentButtonStyle}" />
                </StackPanel>
            </TitleBar.RightHeader>


            <!--<StackPanel
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,8,0"
                        FontSize="24"
                        Text="🌟" />
                    <TextBlock
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="White"
                        Opacity="0.8"
                        Text="{x:Bind ViewModel.AppVersion, Mode=OneWay}" />
                </StackPanel>-->
        </TitleBar>

        <!--  导航面板 / Navigation Panel  -->
        <NavigationView
            Grid.Row="1"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,0,1,0">
            <NavigationView.MenuItems>
                <StackPanel Padding="8" Spacing="4">
                    <!--  主页 / Home  -->
                    <RadioButton
                        Width="180"
                        HorizontalAlignment="Left"
                        Command="{x:Bind ViewModel.NavigateToPageCommand}"
                        CommandParameter="0"
                        Content="🏠 主页 / Home"
                        IsChecked="{x:Bind ViewModel.IsHomePageSelected, Mode=TwoWay}" />

                    <!--  网络状态 / Network Status  -->
                    <RadioButton
                        Width="180"
                        HorizontalAlignment="Left"
                        Command="{x:Bind ViewModel.NavigateToPageCommand}"
                        CommandParameter="1"
                        Content="🌐 网络状态 / Network"
                        IsChecked="{x:Bind ViewModel.IsNetworkPageSelected, Mode=TwoWay}" />

                    <!--  节点列表 / Peer List  -->
                    <RadioButton
                        Width="180"
                        HorizontalAlignment="Left"
                        Command="{x:Bind ViewModel.NavigateToPageCommand}"
                        CommandParameter="2"
                        Content="👥 节点列表 / Peers"
                        IsChecked="{x:Bind ViewModel.IsPeerPageSelected, Mode=TwoWay}" />

                    <!--  文件传输 / File Transfer  -->
                    <RadioButton
                        Width="180"
                        HorizontalAlignment="Left"
                        Command="{x:Bind ViewModel.NavigateToPageCommand}"
                        CommandParameter="3"
                        Content="📁 文件传输 / Transfer"
                        IsChecked="{x:Bind ViewModel.IsTransferPageSelected, Mode=TwoWay}" />

                    <!--  设置 / Settings  -->
                    <RadioButton
                        Width="180"
                        HorizontalAlignment="Left"
                        Command="{x:Bind ViewModel.NavigateToPageCommand}"
                        CommandParameter="4"
                        Content="⚙️ 设置 / Settings"
                        IsChecked="{x:Bind ViewModel.IsSettingsPageSelected, Mode=TwoWay}" />

                    <Rectangle
                        Height="1"
                        Margin="8,16"
                        Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

                    <!--  快速统计 / Quick Statistics  -->
                    <TextBlock
                        Margin="8,0"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="快速统计 / Quick Stats" />

                    <StackPanel Margin="8,8,8,0" Spacing="4">
                        <TextBlock>
                            <Run Text="连接节点 / Connected:" />
                            <Run FontWeight="Bold" Text="{x:Bind ViewModel.ConnectedPeersCount, Mode=OneWay}" />
                        </TextBlock>
                        <TextBlock>
                            <Run Text="活跃传输 / Active:" />
                            <Run FontWeight="Bold" Text="{x:Bind ViewModel.ActiveTransfersCount, Mode=OneWay}" />
                        </TextBlock>
                        <TextBlock>
                            <Run Text="传输总量 / Total:" />
                            <Run FontWeight="Bold" Text="{x:Bind ViewModel.TotalBytesTransferredText, Mode=OneWay}" />
                        </TextBlock>
                        <TextBlock>
                            <Run Text="当前速度 / Speed:" />
                            <Run FontWeight="Bold" Text="{x:Bind ViewModel.CurrentTransferSpeedText, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
            </NavigationView.MenuItems>
        </NavigationView>

        <!--  状态栏 / Status Bar  -->
        <Border
            Grid.Row="2"
            Padding="16,8"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel
                    Grid.Column="0"
                    Orientation="Horizontal"
                    Spacing="16">
                    <!--  错误信息 / Error Information  -->
                    <StackPanel
                        Orientation="Horizontal"
                        Spacing="8"
                        Visibility="{x:Bind ViewModel.HasError, Mode=OneWay}">
                        <TextBlock FontSize="12" Text="❌" />
                        <TextBlock
                            FontSize="12"
                            Foreground="Red"
                            Text="{x:Bind ViewModel.LastError, Mode=OneWay}" />
                        <Button
                            Width="20"
                            Height="20"
                            Command="{x:Bind ViewModel.ClearErrorCommand}"
                            Content="✖"
                            FontSize="10" />
                    </StackPanel>

                    <!--  通知信息 / Notification Information  -->
                    <StackPanel
                        Orientation="Horizontal"
                        Spacing="8"
                        Visibility="{x:Bind ViewModel.HasNotification, Mode=OneWay}">
                        <TextBlock FontSize="12" Text="ℹ️" />

                        <!--  Foreground="{ThemeResource SystemAccentColor}"  -->
                        <TextBlock FontSize="12" Text="{x:Bind ViewModel.LastNotification, Mode=OneWay}" />
                    </StackPanel>
                </StackPanel>

                <StackPanel
                    Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="16">
                    <TextBlock>
                        <Run Text="用户 / User: " />
                        <Run FontWeight="Bold" Text="{x:Bind ViewModel.UserName, Mode=OneWay}" />
                    </TextBlock>
                    <TextBlock>
                        <Run Text="设备 / Device: " />
                        <Run FontWeight="Bold" Text="{x:Bind ViewModel.DeviceName, Mode=OneWay}" />
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
